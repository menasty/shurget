<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    /* ── Admin Login — Shurget Brand System ── */
    *, *::before, *::after { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      background: #0a0a0a;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 2rem 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Radial glow backdrop */
    body::before {
      content: '';
      position: fixed;
      top: -100px;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 500px;
      background: radial-gradient(ellipse, rgba(234,88,12,.13) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
    }

    .login-wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
    }

    /* Logo / brand mark above card */
    .login-brand {
      text-align: center;
      margin-bottom: 2rem;
    }
    .login-brand-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.4rem;
      letter-spacing: .14em;
      color: #fff;
      line-height: 1;
    }
    .login-brand-logo span { color: #ea580c; }
    .login-brand-sub {
      font-family: 'DM Sans', sans-serif;
      font-size: .78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: rgba(255,255,255,.35);
      margin-top: .35rem;
    }

    /* Card */
    .login-card {
      background: #111;
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 16px;
      padding: 2.5rem 2.25rem;
      box-shadow: 0 24px 60px rgba(0,0,0,.6);
    }
    .login-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: .08em;
      color: #fff;
      margin-bottom: .25rem;
    }
    .login-card-sub {
      font-family: 'DM Sans', sans-serif;
      font-size: .82rem;
      color: rgba(255,255,255,.38);
      margin-bottom: 2rem;
    }

    /* Error state */
    .login-error {
      background: rgba(220,38,38,.1);
      border: 1px solid rgba(220,38,38,.35);
      border-radius: 8px;
      padding: .75rem 1rem;
      font-family: 'DM Sans', sans-serif;
      font-size: .85rem;
      color: #fca5a5;
      margin-bottom: 1.25rem;
    }

    /* Form */
    .form-group { margin-bottom: 1.25rem; }
    .form-label {
      display: block;
      font-family: 'DM Sans', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: rgba(255,255,255,.5);
      margin-bottom: .4rem;
    }
    .form-input {
      width: 100%;
      padding: .8rem 1rem;
      background: #0a0a0a;
      border: 1.5px solid rgba(255,255,255,.12);
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      color: #fff;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .form-input::placeholder { color: rgba(255,255,255,.25); }
    .form-input:focus {
      border-color: #ea580c;
      box-shadow: 0 0 0 3px rgba(234,88,12,.12);
    }

    /* Submit button */
    .login-btn {
      width: 100%;
      padding: .9rem;
      background: #b84000;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.2rem;
      letter-spacing: .1em;
      cursor: pointer;
      transition: background .2s, transform .15s;
      margin-top: .5rem;
    }
    .login-btn:hover { background: #9e3800; transform: translateY(-1px); }
    .login-btn:focus-visible { outline: 2px solid #ea580c; outline-offset: 2px; }

    /* Back link */
    .login-footer {
      text-align: center;
      margin-top: 1.5rem;
      font-family: 'DM Sans', sans-serif;
      font-size: .78rem;
      color: rgba(255,255,255,.3);
    }
    .login-footer a {
      color: rgba(255,255,255,.45);
      text-decoration: none;
      transition: color .15s;
    }
    .login-footer a:hover { color: #ea580c; }

    /* Orange bottom accent line on card */
    .login-card::after {
      content: '';
      display: block;
      height: 3px;
      background: linear-gradient(90deg, #b84000, #ea580c);
      border-radius: 0 0 16px 16px;
      margin: 2rem -2.25rem -2.5rem;
    }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-brand">
      <div class="login-brand-logo">SHUR<span>GET</span></div>
      <div class="login-brand-sub">Admin Portal</div>
    </div>

    <div class="login-card">
      <div class="login-card-title">Sign In</div>
      <p class="login-card-sub">Restricted access — authorized personnel only.</p>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input class="form-input" type="text" id="username" name="username" autocomplete="username" required autofocus placeholder="admin">
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
        </div>
        <button type="submit" class="login-btn">Access Admin →</button>
      </form>
    </div>

    <div class="login-footer">
      <a href="/">← Back to Shurget</a>
    </div>
  </div>
</body>
</html>
