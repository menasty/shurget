<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bookings — Shurget Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #0a0a0a; color: #f8f7f5; font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    .admin-topnav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,.92); backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,.07);
      height: 58px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 clamp(1.25rem,4vw,2.5rem);
    }
    .admin-topnav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .12em; color: #fff; text-decoration: none; display: flex; align-items: center; gap: .5rem; }
    .admin-topnav-logo span { color: #ea580c; }
    .admin-topnav-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(234,88,12,.15); color: #ea580c; border: 1px solid rgba(234,88,12,.3); border-radius: 4px; padding: .15rem .5rem; }
    .tn-btn { font-size: .78rem; font-weight: 600; text-decoration: none; padding: .4rem .9rem; border-radius: 6px; border: none; cursor: pointer; transition: background .2s; font-family: 'DM Sans', sans-serif; }
    .tn-btn-ghost { background: rgba(255,255,255,.07); color: rgba(255,255,255,.65); }
    .tn-btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; }
    .tn-btn-primary { background: #b84000; color: #fff; }
    .tn-btn-primary:hover { background: #9e3800; }

    .admin-layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 58px); }
    @media (max-width: 768px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { display: flex; overflow-x: auto; padding: .75rem; gap: .4rem; border-right: none; border-bottom: 1px solid rgba(255,255,255,.07); } .sidebar-section-label { display: none; } }
    .admin-sidebar { background: #111; border-right: 1px solid rgba(255,255,255,.07); padding: 1.25rem .75rem; display: flex; flex-direction: column; gap: .15rem; }
    .sidebar-section-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.3); padding: .9rem .6rem .35rem; }
    .sidebar-link { display: flex; align-items: center; gap: .6rem; padding: .52rem .7rem; border-radius: 7px; text-decoration: none; color: rgba(255,255,255,.55); font-size: .82rem; font-weight: 500; transition: all .18s; white-space: nowrap; }
    .sidebar-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
    .sidebar-link.active { background: rgba(184,64,0,.18); color: #ea580c; font-weight: 600; }
    .sidebar-icon { font-size: 1rem; flex-shrink: 0; }
    .admin-main { padding: clamp(1.5rem,4vw,2.5rem); overflow-x: hidden; }

    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: .06em; color: #fff; margin: 0 0 .25rem; }
    .page-subtitle { font-size: .88rem; color: rgba(255,255,255,.45); margin: 0 0 1.75rem; }

    .card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.5rem; }
    .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; }

    .data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .data-table th { background: #111; color: rgba(255,255,255,.45); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; padding: .65rem 1rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,.07); white-space: nowrap; }
    .data-table th.sortable { cursor: pointer; user-select: none; }
    .data-table th.sortable:hover { color: #ea580c; }
    .data-table td { padding: .75rem 1rem; border-bottom: 1px solid rgba(255,255,255,.04); color: #f8f7f5; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: rgba(255,255,255,.03); }
    .table-wrap { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; overflow: hidden; }

    .badge { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: .25rem .6rem; border-radius: 5px; }
    .badge-green  { background: rgba(22,163,74,.15);  color: #4ade80; border: 1px solid rgba(22,163,74,.25); }
    .badge-orange { background: rgba(234,88,12,.15);  color: #ea580c; border: 1px solid rgba(234,88,12,.25); }
    .badge-red    { background: rgba(239,68,68,.15);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .badge-gray   { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.1); }
    .badge-blue   { background: rgba(59,130,246,.15); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }

    .btn { display: inline-flex; align-items: center; gap: .4rem; font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600; padding: .5rem 1rem; border-radius: 7px; border: none; cursor: pointer; text-decoration: none; transition: all .2s; }
    .btn-primary { background: #b84000; color: #fff; }
    .btn-primary:hover { background: #9e3800; }
    .btn-ghost { background: rgba(255,255,255,.06); color: rgba(255,255,255,.65); border: 1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { background: rgba(255,255,255,.1); color: #fff; }
    .btn-danger { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .btn-danger:hover { background: rgba(239,68,68,.25); }
    .btn-sm { padding: .35rem .7rem; font-size: .72rem; }

    .form-input { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; transition: border-color .2s; }
    .form-input:focus { border-color: #b84000; }
    .form-select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .82rem; padding: .4rem .7rem; outline: none; cursor: pointer; }
    .form-select:focus { border-color: #b84000; }

    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.75rem; }
    .metric-card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.25rem 1.5rem; }
    .metric-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin: 0 0 .4rem; }
    .metric-value { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: .04em; color: #fff; line-height: 1; margin: 0; }
    .metric-sub { font-size: .75rem; color: rgba(255,255,255,.35); margin: .3rem 0 0; }

    .alert { border-radius: 9px; padding: .75rem 1.1rem; font-size: .88rem; margin-bottom: 1.25rem; }
    .alert-success { background: rgba(22,163,74,.12); border: 1px solid rgba(22,163,74,.25); color: #4ade80; }
    .alert-error { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25); color: #f87171; }

    /* Filter bar */
    .filter-bar { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 1.5rem; background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1rem 1.25rem; }
    .filter-group { display: flex; align-items: center; gap: .5rem; }
    .filter-label { font-size: .72rem; font-weight: 700; color: rgba(255,255,255,.45); text-transform: uppercase; letter-spacing: .08em; }
    .results-count { margin-left: auto; font-size: .82rem; color: rgba(255,255,255,.45); }

    .order-id-badge { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 4px; padding: .2rem .5rem; font-size: .78rem; font-weight: 700; font-family: monospace; color: #f8f7f5; }
    .customer-name { font-weight: 600; }
    .customer-email { font-size: .78rem; color: rgba(255,255,255,.45); }
    .address-text { font-size: .82rem; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .price-value { font-weight: 700; font-size: .9rem; }
    .price-breakdown { font-size: .72rem; color: rgba(255,255,255,.35); margin-top: .1rem; }
    .driver-name { font-weight: 500; font-size: .82rem; }
    .driver-phone { font-size: .75rem; color: rgba(255,255,255,.45); }
    .date-text { font-size: .8rem; color: rgba(255,255,255,.45); }
    .actions-cell { display: flex; gap: .4rem; align-items: center; }

    /* Empty state */
    .empty-state { text-align: center; padding: 3rem 1rem; color: rgba(255,255,255,.45); }
    .empty-state-icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: #fff; margin-bottom: .5rem; letter-spacing: .04em; }
    .empty-state p { font-size: .9rem; }

    /* Detail Drawer */
    .drawer-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 200; backdrop-filter: blur(2px); }
    .drawer-overlay.open { display: block; }
    .drawer { position: fixed; top: 0; right: 0; bottom: 0; width: min(560px, 100vw); background: #111; border-left: 1px solid rgba(255,255,255,.07); z-index: 201; overflow-y: auto; transform: translateX(100%); transition: transform .25s ease; box-shadow: -8px 0 32px rgba(0,0,0,.5); }
    .drawer.open { transform: translateX(0); }
    .drawer-header { position: sticky; top: 0; background: #111; border-bottom: 1px solid rgba(255,255,255,.07); padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: space-between; z-index: 1; }
    .drawer-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .05em; color: #fff; }
    .drawer-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: rgba(255,255,255,.45); padding: .25rem; line-height: 1; }
    .drawer-close:hover { color: #fff; }
    .drawer-body { padding: 1.5rem; }
    .detail-section { margin-bottom: 1.75rem; }
    .detail-section-title { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin-bottom: .75rem; }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .detail-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.35); margin-bottom: .2rem; }
    .detail-value { font-size: .88rem; font-weight: 500; color: #f8f7f5; }
    .detail-full { margin-bottom: .5rem; }
    .detail-full .detail-label { margin-bottom: .15rem; }
    .detail-full .detail-value { font-size: .88rem; line-height: 1.4; }
    .price-box { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 8px; padding: 1rem; }
    .price-box .price-row { display: flex; justify-content: space-between; font-size: .85rem; margin-bottom: .4rem; color: #f8f7f5; }
    .price-box .price-row:last-child { margin-bottom: 0; padding-top: .5rem; border-top: 1px solid rgba(255,255,255,.08); font-weight: 700; font-size: 1rem; }
    .price-box .price-row .muted { color: rgba(255,255,255,.45); }
    .items-list { list-style: none; padding: 0; margin: 0; }
    .items-list li { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08); border-radius: 6px; padding: .6rem .85rem; margin-bottom: .4rem; font-size: .85rem; color: #f8f7f5; }
    .items-list li:last-child { margin-bottom: 0; }
    .drawer-actions { display: flex; gap: .75rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,.07); }
    .drawer-actions .btn { flex: 1; justify-content: center; padding: .75rem 1rem; font-size: .88rem; }
    .reassign-form { margin-top: 1rem; }
    .reassign-form select { width: 100%; margin-bottom: .5rem; }

    @media (max-width: 768px) {
      .detail-grid { grid-template-columns: 1fr; }
      .filter-bar { flex-direction: column; align-items: flex-start; }
      .results-count { margin-left: 0; }
    }
  </style>
</head>
<body>

  <!-- Top Nav -->
  <header class="admin-topnav">
    <a href="/admin" class="admin-topnav-logo">SHUR<span>GET</span> <span class="admin-topnav-badge">Admin</span></a>
    <div style="display:flex;align-items:center;gap:.65rem;">
      <a href="/admin" class="tn-btn tn-btn-ghost">← Dashboard</a>
      <a href="/admin/logout" class="tn-btn tn-btn-primary">Logout</a>
    </div>
  </header>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-section-label">Operations</div>
      <a href="/admin/dispatch" class="sidebar-link"><span class="sidebar-icon">🚛</span> Dispatch</a>
      <a href="/admin/bookings" class="sidebar-link active"><span class="sidebar-icon">📋</span> Bookings</a>
      <a href="/admin/drivers" class="sidebar-link"><span class="sidebar-icon">🧑‍✈️</span> Drivers</a>
      <div class="sidebar-section-label">Analytics</div>
      <a href="/admin/metrics" class="sidebar-link"><span class="sidebar-icon">📊</span> Metrics</a>
      <a href="/admin/ratings" class="sidebar-link"><span class="sidebar-icon">⭐</span> Ratings</a>
      <a href="/admin/attribution" class="sidebar-link"><span class="sidebar-icon">🔗</span> Attribution</a>
      <div class="sidebar-section-label">Platform</div>
      <a href="/admin/partners" class="sidebar-link"><span class="sidebar-icon">🤝</span> Partners</a>
      <a href="/admin/disputes" class="sidebar-link"><span class="sidebar-icon">⚖️</span> Disputes</a>
      <a href="/admin/surge" class="sidebar-link"><span class="sidebar-icon">⚡</span> Surge</a>
    </aside>

    <main class="admin-main">
      <h1 class="page-title">Bookings</h1>
      <p class="page-subtitle">All orders — full history with filters, sort, and detail view.</p>

      <!-- Flash alerts -->
      <% if (flash === 'cancelled') { %>
        <div class="alert alert-success">Order cancelled successfully.</div>
      <% } %>
      <% if (flash === 'assigned') { %>
        <div class="alert alert-success">Driver assigned successfully.</div>
      <% } %>

      <!-- Filter bar -->
      <form method="get" class="filter-bar">
        <input type="hidden" name="admin" value="<%= adminEmail || '' %>">

        <div class="filter-group">
          <span class="filter-label">Status</span>
          <select name="status" class="form-select" onchange="this.form.submit()">
            <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>All</option>
            <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="paid" <%= filters.status === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="assigned" <%= filters.status === 'assigned' ? 'selected' : '' %>>Assigned</option>
            <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
            <option value="delivered" <%= filters.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
            <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>

        <div class="filter-group">
          <span class="filter-label">Sort</span>
          <select name="sort" class="form-select" onchange="this.form.submit()">
            <option value="created_at" <%= filters.sort === 'created_at' ? 'selected' : '' %>>Date</option>
            <option value="price_total" <%= filters.sort === 'price_total' ? 'selected' : '' %>>Price</option>
            <option value="status" <%= filters.sort === 'status' ? 'selected' : '' %>>Status</option>
          </select>
        </div>

        <div class="filter-group">
          <span class="filter-label">Direction</span>
          <select name="dir" class="form-select" onchange="this.form.submit()">
            <option value="desc" <%= filters.dir === 'desc' ? 'selected' : '' %>>Newest First</option>
            <option value="asc" <%= filters.dir === 'asc' ? 'selected' : '' %>>Oldest First</option>
          </select>
        </div>

        <a href="/admin/bookings" class="btn btn-ghost">Clear filters</a>

        <span class="results-count"><%= total %> order<%= total === 1 ? '' : 's' %></span>
      </form>

      <!-- Orders table -->
      <% if (orders.length === 0) { %>
        <div class="table-wrap">
          <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h2>No orders found</h2>
            <p>Try adjusting your filters.</p>
          </div>
        </div>
      <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th class="sortable" onclick="sortBy('id')">#</th>
                <th>Customer</th>
                <th>Pickup</th>
                <th>Dropoff</th>
                <th>Item</th>
                <th class="sortable" onclick="sortBy('price_total')">Price</th>
                <th class="sortable" onclick="sortBy('status')">Status</th>
                <th>Driver</th>
                <th>Payout</th>
                <th class="sortable" onclick="sortBy('created_at')">Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% for (const order of orders) { %>
                <tr onclick="openDrawer(<%= order.id %>)" data-order-id="<%= order.id %>" style="cursor:pointer;">
                  <td><span class="order-id-badge">#<%= order.id %></span></td>
                  <td>
                    <div class="customer-name"><%= order.customer_name || '—' %></div>
                    <% if (order.customer_email) { %>
                      <div class="customer-email"><%= order.customer_email %></div>
                    <% } %>
                  </td>
                  <td>
                    <div class="address-text" title="<%= order.pickup_address %>"><%= order.pickup_address || '—' %></div>
                  </td>
                  <td>
                    <div class="address-text" title="<%= order.dropoff_address %>"><%= order.dropoff_address || '—' %></div>
                  </td>
                  <td>
                    <div style="font-size:0.85rem; font-weight:500;"><%= ((order.item_type || '').replace(/-/g, ' ')).replace(/\b\//g, m => m[1] ? m[1].toUpperCase() : m) %></div>
                    <% if (order.distance_miles) { %>
                      <div style="font-size:0.75rem; color:rgba(255,255,255,.35);"><%= Number(order.distance_miles).toFixed(1) %> mi</div>
                    <% } %>
                  </td>
                  <td>
                    <div class="price-value">$<%= Number(order.price_total).toFixed(2) %></div>
                    <% if (order.price_base) { %>
                      <div class="price-breakdown">base $<%= Number(order.price_base).toFixed(2) %></div>
                    <% } %>
                  </td>
                  <td>
                    <% const bStatus = order.status; %>
                    <% const bBadge = (bStatus === 'delivered') ? 'badge-green' : (bStatus === 'paid' || bStatus === 'assigned' || bStatus === 'in_progress') ? 'badge-blue' : (bStatus === 'cancelled') ? 'badge-red' : 'badge-orange'; %>
                    <span class="badge <%= bBadge %>"><%= order.status.replace('_', ' ') %></span>
                    <% if (order.driver_status === 'accepted') { %>
                      <div style="font-size:0.7rem; color:rgba(255,255,255,.35); margin-top:0.2rem;">accepted</div>
                    <% } %>
                  </td>
                  <td>
                    <% if (order.driver_name) { %>
                      <div class="driver-name"><%= order.driver_name %></div>
                      <% if (order.driver_phone) { %>
                        <div class="driver-phone"><%= order.driver_phone %></div>
                      <% } %>
                    <% } else { %>
                      <div style="color:rgba(255,255,255,.35); font-size:0.82rem;">—</div>
                    <% } %>
                  </td>
                  <td>
                    <% if (order.status === 'delivered') { %>
                      <% const ps = order.payout_status || 'pending'; %>
                      <% const psColors = { paid: '#4ade80', pending: '#ea580c', failed: '#f87171', na: 'rgba(255,255,255,.35)' }; %>
                      <span style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:<%= psColors[ps] || 'rgba(255,255,255,.35)' %>">
                        <%= ps %>
                      </span>
                      <% if (order.stripe_transfer_id) { %>
                        <div style="font-size:.65rem;color:rgba(255,255,255,.35);font-family:monospace;margin-top:.1rem;"><%= order.stripe_transfer_id.slice(0,10) %>…</div>
                      <% } %>
                    <% } else { %>
                      <span style="font-size:.7rem;color:rgba(255,255,255,.35);">N/A</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="date-text"><%= new Date(order.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric'}) %></div>
                    <div style="font-size:0.72rem; color:rgba(255,255,255,.35);"><%= new Date(order.created_at).toLocaleTimeString('en-US', {hour:'numeric',minute:'2-digit'}) %></div>
                  </td>
                  <td onclick="event.stopPropagation()">
                    <div class="actions-cell">
                      <% if (order.status !== 'cancelled' && order.status !== 'delivered') { %>
                        <form method="post" action="/admin/bookings/<%= order.id %>/cancel" onsubmit="return confirm('Cancel order #<%= order.id %>? This cannot be undone.');" style="display:inline;">
                          <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                        </form>
                      <% } %>
                      <button class="btn btn-ghost btn-sm" onclick="openDrawer(<%= order.id %>)">View</button>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>
    </main>
  </div>

  <!-- Detail Drawer -->
  <div class="drawer-overlay" id="drawerOverlay" onclick="closeDrawer()"></div>
  <div class="drawer" id="drawer">
    <div class="drawer-header">
      <span class="drawer-title" id="drawerTitle">Order Details</span>
      <button class="drawer-close" onclick="closeDrawer()">×</button>
    </div>
    <div class="drawer-body" id="drawerBody">
      <!-- populated by JS -->
    </div>
  </div>

  <script>
    // Order data embedded for JS access
    const allOrders = <%- JSON.stringify(orders) %>;
    const driversList = <%- JSON.stringify(drivers.map(d => ({ id: d.id, name: d.name, phone: d.phone, city: d.city, vehicle_type: d.vehicle_type }))) %>;

    function statusBadgeClass(status) {
      if (status === 'delivered') return 'badge-green';
      if (status === 'paid' || status === 'assigned' || status === 'in_progress') return 'badge-blue';
      if (status === 'cancelled') return 'badge-red';
      return 'badge-orange';
    }

    function openDrawer(orderId) {
      const order = allOrders.find(o => o.id === orderId);
      if (!order) return;

      const body = document.getElementById('drawerBody');
      const title = document.getElementById('drawerTitle');

      title.textContent = `Order #${order.id}`;

      const items = Array.isArray(order.items) ? order.items : [];
      const itemsHTML = items.length > 0
        ? items.map(it => `<li><strong>${it.description || 'Item'}</strong>${it.quantity > 1 ? ' ×' + it.quantity : ''} ${it.length_in ? `· ${it.length_in}×${it.width_in || '?'}×${it.height_in || '?'} in` : ''}</li>`).join('')
        : '<li style="color:rgba(255,255,255,.45);">No item details recorded.</li>';

      const badgeClass = statusBadgeClass(order.status);
      const canCancel = order.status !== 'cancelled' && order.status !== 'delivered';

      body.innerHTML = `
        <div class="detail-section">
          <div class="detail-section-title">Status</div>
          <span class="badge ${badgeClass}">${order.status.replace('_', ' ')}</span>
          ${order.driver_status ? `<div style="margin-top:0.5rem; font-size:0.82rem; color:rgba(255,255,255,.45);">Driver status: ${order.driver_status}</div>` : ''}
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Customer</div>
          <div class="detail-grid">
            <div class="detail-item">
              <div class="detail-label">Name</div>
              <div class="detail-value">${order.customer_name || '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Email</div>
              <div class="detail-value">${order.customer_email || '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Phone</div>
              <div class="detail-value">${order.customer_phone || '—'}</div>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Route</div>
          <div class="detail-full">
            <div class="detail-label">Pickup</div>
            <div class="detail-value">${order.pickup_address || '—'}</div>
          </div>
          <div class="detail-full">
            <div class="detail-label">Dropoff</div>
            <div class="detail-value">${order.dropoff_address || '—'}</div>
          </div>
          <div class="detail-grid">
            <div class="detail-item">
              <div class="detail-label">Distance</div>
              <div class="detail-value">${order.distance_miles ? Number(order.distance_miles).toFixed(1) + ' mi' : '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Item Type</div>
              <div class="detail-value" style="text-transform:capitalize;">${(order.item_type || '').replace(/-/g, ' ')}</div>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Items</div>
          <ul class="items-list">${itemsHTML}</ul>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Pricing</div>
          <div class="price-box">
            <div class="price-row">
              <span class="muted">Base rate</span>
              <span>${order.price_base ? '$' + Number(order.price_base).toFixed(2) : '—'}</span>
            </div>
            <div class="price-row">
              <span class="muted">Service fee (15%)</span>
              <span>${order.price_fee ? '$' + Number(order.price_fee).toFixed(2) : '—'}</span>
            </div>
            <div class="price-row">
              <span>Total</span>
              <span>$${Number(order.price_total || 0).toFixed(2)}</span>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Driver</div>
          <div class="detail-grid">
            <div class="detail-item">
              <div class="detail-label">Name</div>
              <div class="detail-value">${order.driver_name || '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Phone</div>
              <div class="detail-value">${order.driver_phone || '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">ETA</div>
              <div class="detail-value">${order.eta_minutes ? order.eta_minutes + ' min' : '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Accepted</div>
              <div class="detail-value">${order.driver_status || '—'}</div>
            </div>
          </div>
        </div>

        <div class="detail-section">
          <div class="detail-section-title">Timeline</div>
          <div class="detail-grid">
            <div class="detail-item">
              <div class="detail-label">Created</div>
              <div class="detail-value">${new Date(order.created_at).toLocaleString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit'})}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Confirmed</div>
              <div class="detail-value">${order.confirmed_at ? new Date(order.confirmed_at).toLocaleString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) : '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Paid</div>
              <div class="detail-value">${order.paid_at ? new Date(order.paid_at).toLocaleString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) : '—'}</div>
            </div>
            <div class="detail-item">
              <div class="detail-label">Updated</div>
              <div class="detail-value">${order.updated_at ? new Date(order.updated_at).toLocaleString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) : '—'}</div>
            </div>
          </div>
        </div>

        <div class="drawer-actions">
          ${canCancel ? `
            <form method="post" action="/admin/bookings/${order.id}/cancel" onsubmit="return confirm('Cancel order #' + ${order.id} + '? This cannot be undone.');" style="flex:1;">
              <button type="submit" class="btn btn-danger" style="width:100%;">Cancel Order</button>
            </form>
          ` : `<div class="btn btn-ghost" style="flex:1;cursor:default;">${order.status === 'delivered' ? 'Completed' : 'Cancelled'}</div>`}
        </div>

        ${canCancel ? `
        <div class="reassign-form" style="margin-top:1rem;">
          <div class="detail-section-title">Reassign Driver</div>
          <form method="post" action="/admin/bookings/${order.id}/reassign">
            <select name="driverId" class="form-select" style="width:100%;" required>
              <option value="">Select a driver…</option>
              ${driversList.map(d => `<option value="${d.id}">${d.name} · ${d.city} · ${d.vehicle_type}</option>`).join('')}
            </select>
            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:.5rem;justify-content:center;">Assign Driver</button>
          </form>
        </div>
        ` : ''}
      `;

      document.getElementById('drawerOverlay').classList.add('open');
      document.getElementById('drawer').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      document.getElementById('drawerOverlay').classList.remove('open');
      document.getElementById('drawer').classList.remove('open');
      document.body.style.overflow = '';
    }

    function sortBy(field) {
      const params = new URLSearchParams(window.location.search);
      const currentSort = params.get('sort') || 'created_at';
      const currentDir = params.get('dir') || 'desc';
      params.set('sort', field);
      params.set('dir', field === currentSort && currentDir === 'desc' ? 'asc' : 'desc');
      window.location.search = params.toString();
    }

    // ESC key closes drawer
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });
  </script>
</body>
</html>
