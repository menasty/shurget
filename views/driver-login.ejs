<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Driver Login — Shurget</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #111111;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #1c1c1c;
      border-radius: 14px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      padding: 40px 36px;
      width: 100%;
      max-width: 400px;
      border: 1px solid #2a2a2a;
    }
    .logo-wrap {
      text-align: center;
      margin-bottom: 20px;
    }
    .logo-wrap img {
      height: 64px;
      width: auto;
      object-fit: contain;
    }
    .subtitle {
      font-size: 14px;
      color: #888;
      margin-bottom: 28px;
      text-align: center;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #ccc;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #333;
      border-radius: 8px;
      font-size: 15px;
      margin-bottom: 18px;
      outline: none;
      background: #111;
      color: #fff;
      transition: border-color 0.15s;
    }
    input:focus { border-color: #ea580c; }
    input::placeholder { color: #555; }
    .hint {
      font-size: 12px;
      color: #666;
      margin-top: -14px;
      margin-bottom: 18px;
    }
    button {
      width: 100%;
      padding: 13px;
      background: #ea580c;
      color: #fff;
      font-size: 16px;
      font-weight: 700;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.15s;
    }
    button:hover { background: #d14a00; }
    .error {
      background: rgba(220,38,38,0.12);
      border: 1px solid rgba(220,38,38,0.4);
      color: #f87171;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 14px;
      margin-bottom: 18px;
    }
    .apply-link {
      text-align: center;
      margin-top: 20px;
      font-size: 13px;
      color: #666;
    }
    .apply-link a { color: #ea580c; text-decoration: none; font-weight: 600; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo-wrap">
      <img src="/images/shurget-logo-decal.jpg" alt="Shurget" />
    </div>
    <div class="subtitle">Driver Portal — Sign in to view jobs</div>

    <% if (locals.error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/driver/login">
      <label for="email">Email address</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="you@example.com"
        autocomplete="email"
        required
      />

      <label for="pin">Last 4 digits of your phone</label>
      <input
        type="text"
        id="pin"
        name="pin"
        placeholder="e.g. 4521"
        maxlength="4"
        pattern="\d{4}"
        inputmode="numeric"
        autocomplete="off"
        required
      />
      <p class="hint">The phone number you used when applying</p>

      <button type="submit">Sign In</button>
    </form>

    <div class="apply-link">
      Not a driver yet? <a href="/drive">Apply now</a>
    </div>
  </div>
</body>
</html>
