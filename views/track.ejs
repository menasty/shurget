<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Track Order #<%= order.id %> — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: var(--bg); }

    .track-page {
      max-width: 560px;
      margin: 0 auto;
      padding: 80px 1.5rem 3rem;
      min-height: 100vh;
    }

    /* ── Header ── */
    .track-header { text-align: center; margin-bottom: 2rem; }
    .track-header .order-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--orange);
      margin-bottom: 0.4rem;
    }
    .track-header .order-id-display {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2rem;
      letter-spacing: 0.1em;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
    }
    .track-header .order-date {
      font-size: 0.85rem;
      color: var(--gray-mid);
    }

    /* ── Status stage tracker ── */
    .stage-tracker {
      display: flex;
      align-items: center;
      margin-bottom: 2rem;
      position: relative;
    }
    .stage-tracker::before {
      content: '';
      position: absolute;
      top: 18px;
      left: 28px;
      right: 28px;
      height: 2px;
      background: var(--gray-light);
    }
    .stage {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      position: relative;
      z-index: 1;
    }
    .stage-dot {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--white);
      border: 2px solid var(--gray-light);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      color: var(--gray-light);
      transition: all 0.3s;
    }
    .stage.done .stage-dot {
      background: var(--orange);
      border-color: var(--orange);
      color: var(--white);
    }
    .stage.active .stage-dot {
      background: var(--orange);
      border-color: var(--orange);
      color: var(--white);
      box-shadow: 0 0 0 6px rgba(232,93,4,0.15);
    }
    .stage-label {
      font-size: 0.65rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray-light);
      text-align: center;
    }
    .stage.done .stage-label, .stage.active .stage-label { color: var(--orange); }

    /* ── Driver card ── */
    .driver-card {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .driver-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: var(--orange);
      color: var(--white);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .driver-meta .driver-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--orange);
      margin-bottom: 0.25rem;
    }
    .driver-meta .driver-name {
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--charcoal);
    }
    .driver-meta .driver-phone {
      font-size: 0.9rem;
      color: var(--gray-mid);
      margin-top: 0.2rem;
    }

    /* ── Call driver button ── */
    .call-driver-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      width: 100%;
      padding: 1rem;
      background: var(--orange);
      color: var(--white);
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 1.5rem;
    }
    .call-driver-btn:hover { background: var(--orange-light); }

    /* ── ETA badge ── */
    .eta-badge {
      background: #F0FAF5;
      border: 1.5px solid #86C9A0;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .eta-icon { font-size: 1.5rem; }
    .eta-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--orange);
    }
    .eta-time {
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--charcoal);
    }

    /* ── Summary card ── */
    .summary-card {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .summary-card h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      margin-bottom: 1rem;
      color: var(--charcoal);
    }
    .summary-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 0.75rem 0;
      border-bottom: 1px solid #F0F0EE;
      font-size: 0.9rem;
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-row .key { color: var(--gray-mid); }
    .summary-row .val { font-weight: 600; color: var(--charcoal); text-align: right; max-width: 55%; }
    .price-row .key { color: var(--charcoal); font-weight: 600; }
    .price-row .val { font-size: 1.25rem; color: var(--orange); }

    /* ── Map link ── */
    .map-link-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      width: 100%;
      padding: 0.9rem;
      background: var(--charcoal);
      color: var(--white);
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
      margin-bottom: 1rem;
    }
    .map-link-btn:hover { background: var(--slate); }

    /* ── Action buttons ── */
    .action-btns {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .btn-home {
      display: block;
      width: 100%;
      padding: 1rem;
      background: var(--charcoal);
      color: var(--white);
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-align: center;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-home:hover { background: var(--slate); }
    .btn-book-again {
      display: block;
      width: 100%;
      padding: 1rem;
      background: transparent;
      color: var(--orange);
      border: 2px solid var(--orange);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      text-align: center;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-book-again:hover { background: #FEF3E8; }

    /* ── Live location card ── */
    .driver-location-card {
      background: #F0FAF5;
      border: 1.5px solid #86C9A0;
      border-radius: 12px;
      padding: 1rem 1.25rem;
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .location-dot { position: relative; width: 20px; height: 20px; flex-shrink: 0; }
    .pulse-ring {
      position: absolute; inset: -4px;
      border-radius: 50%;
      border: 2px solid #86C9A0;
      animation: pulse 2s infinite;
    }
    .pulse-center {
      width: 20px; height: 20px;
      border-radius: 50%;
      background: #166534;
    }
    @keyframes pulse {
      0%   { transform: scale(0.8); opacity: 1; }
      100% { transform: scale(1.8); opacity: 0; }
    }
    .location-info .location-status-label {
      font-size: 0.9rem; font-weight: 600; color: #166534;
    }
    .location-info .location-update-time {
      font-size: 0.75rem; color: #4D7A5B; margin-top: 0.2rem;
    }

    /* ── Nav ── */
    .track-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(26,26,26,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 60px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem; letter-spacing: 0.12em;
      color: var(--white); text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-btn {
      padding: 0.45rem 1rem; border-radius: 4px;
      font-size: 0.8rem; font-weight: 600; text-decoration: none;
      cursor: pointer; border: none; font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .nav-btn-primary { background: var(--orange); color: var(--white); }
    .nav-btn-primary:hover { background: var(--orange-light); }
    .nav-btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .nav-btn-secondary:hover { background: rgba(255,255,255,0.18); }
  </style>
</head>
<body>
  <nav class="track-nav">
    <a href="/" class="nav-logo">
      <img src="/images/shurget-logo.png" alt="Shurget" height="48" style="vertical-align: middle;">
    </a>
    <div class="nav-right">
      <a href="/contact" class="nav-btn nav-btn-secondary">Contact</a>
      <a href="/dashboard" class="nav-btn nav-btn-secondary">Dashboard</a>
      <a href="/book" class="nav-btn nav-btn-primary">Book Now</a>
    </div>
  </nav>

  <div class="track-page">
    <div class="track-header">
      <div class="order-label">Order Tracking</div>
      <div class="order-id-display">#<%= order.id %></div>
      <div class="order-date">
        <%= new Date(order.created_at).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %>
        &nbsp;·&nbsp;
        <span style="text-transform:capitalize"><%= order.item_type %></span>
      </div>
    </div>

    <% function stageIndex(status) {
      const map = { paid: 0, assigned: 1, in_progress: 2, delivered: 3 };
      return map[status] ?? 0;
    }
    const current = stageIndex(order.status);
    const stages = [
      { label: 'Booked',  key: 'paid' },
      { label: 'Dispatched', key: 'assigned' },
      { label: 'In Progress', key: 'in_progress' },
      { label: 'Completed', key: 'delivered' },
    ]; %>

    <div class="stage-tracker">
      <% stages.forEach(function(stage, i) { %>
        <div class="stage <%= i <= current ? (i === current ? 'active' : 'done') : '' %>">
          <div class="stage-dot">
            <% if (i < current) { %>✓<% } else if (i === current) { %>●<% } else { %><%= i + 1 %><% } %>
          </div>
          <div class="stage-label"><%= stage.label %></div>
        </div>
      <% }) %>
    </div>

    <% if (order.driver_name) { %>
    <div class="driver-card">
      <div class="driver-avatar">
        <%= order.driver_name.split(' ').map(function(n) { return n[0]; }).join('') %>
      </div>
      <div class="driver-meta">
        <div class="driver-label">Your Driver</div>
        <div class="driver-name"><%= order.driver_name %></div>
        <% if (order.driver_phone) { %>
        <div class="driver-phone">📞 <%= order.driver_phone %></div>
        <% } %>
      </div>
    </div>

    <% if (order.driver_phone) { %>
    <a href="tel:<%= order.driver_phone %>" class="call-driver-btn">
      📞 Call <%= order.driver_name.split(' ')[0] %>
    </a>
    <% } %>
    <% } %>

    <% if (order.eta_minutes && (order.status === 'assigned' || order.status === 'in_progress')) { %>
    <div class="eta-badge">
      <div class="eta-icon">🚛</div>
      <div>
        <div class="eta-label">Estimated Arrival</div>
        <div class="eta-time">In <%= order.eta_minutes %> minutes</div>
      </div>
    </div>
    <% } %>

    <div id="driver-location-card" class="driver-location-card" style="display:none">
      <div class="location-dot">
        <div class="pulse-ring"></div>
        <div class="pulse-center"></div>
      </div>
      <div class="location-info">
        <div class="location-status-label">Driver is on the way</div>
        <div class="location-update-time" id="location-update-time"></div>
      </div>
    </div>

    <div class="summary-card">
      <h2>Delivery Details</h2>
      <div class="summary-row">
        <span class="key">Pickup</span>
        <span class="val"><%= order.pickup_address %></span>
      </div>
      <div class="summary-row">
        <span class="key">Drop-off</span>
        <span class="val"><%= order.dropoff_address %></span>
      </div>
      <% if (order.distance_miles) { %>
      <div class="summary-row">
        <span class="key">Distance</span>
        <span class="val"><%= order.distance_miles %> mi</span>
      </div>
      <% } %>
      <% if (order.price_total) { %>
      <div class="summary-row price-row">
        <span class="key">Total</span>
        <span class="val">$<%= Number(order.price_total).toFixed(2) %></span>
      </div>
      <% } %>
    </div>

    <% if (order.pickup_lat && order.pickup_lng) { %>
    <a
      href="https://www.google.com/maps/dir/?api=1&destination=<%= order.pickup_lat %>,<%= order.pickup_lng %>"
      target="_blank"
      rel="noopener noreferrer"
      class="map-link-btn"
    >
      🗺️ Open in Google Maps
    </a>
    <% } %>

    <div class="action-btns">
      <a href="/book" class="btn-home">Book Another Haul</a>
      <% if (order.customer_email) { %>
      <a href="/dashboard?email=<%= encodeURIComponent(order.customer_email) %>" class="btn-book-again">View All My Orders</a>
      <% } %>
    </div>

    <!-- Cancel order section — shown when cancellable -->
    <% if (order && (order.status === 'paid' || order.status === 'assigned')) { %>
    <div style="margin-top:24px;text-align:center;">
      <% if (order.status === 'assigned') { %>
        <p style="color:#aaa;font-size:14px;margin-bottom:8px;">Driver has been assigned. Cancelling now will issue a 50% refund.</p>
      <% } %>
      <button id="cancelOrderBtn" onclick="cancelOrder(<%= order.id %>)" style="background:transparent;border:1px solid #b84000;color:#b84000;padding:10px 28px;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:14px;cursor:pointer;">
        Cancel Order
      </button>
      <p id="cancelMsg" style="color:#aaa;font-size:13px;margin-top:8px;display:none;"></p>
      <% if (order.status === 'assigned') { %>
      <div style="margin-top:12px;">
        <button id="cancelUnpreparedBtn" onclick="cancelUnprepared(<%= order.id %>)"
          style="background:transparent;border:1px solid #555;color:#888;padding:8px 20px;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;">
          Driver arrived without proper equipment?
        </button>
        <p id="unpreparedMsg" style="color:#aaa;font-size:12px;margin-top:6px;display:none;"></p>
      </div>
      <% } %>
    </div>
    <% } else if (order && (order.status === 'in_progress' || order.status === 'delivered')) { %>
    <div style="margin-top:24px;text-align:center;">
      <p style="color:#aaa;font-size:14px;">Your order is underway. Contact support for assistance.</p>
    </div>
    <% } %>

    <script>
    async function cancelOrder(orderId) {
      if (!confirm('Are you sure you want to cancel this order?')) return;
      const btn = document.getElementById('cancelOrderBtn');
      const msg = document.getElementById('cancelMsg');
      btn.disabled = true;
      btn.textContent = 'Cancelling...';
      try {
        const res = await fetch(`/api/orders/${orderId}/cancel`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({}) });
        const data = await res.json();
        if (data.success) {
          btn.style.display = 'none';
          msg.style.display = 'block';
          msg.style.color = '#6daa45';
          msg.textContent = data.message || 'Order cancelled. Refund issued.';
        } else {
          btn.disabled = false;
          btn.textContent = 'Cancel Order';
          msg.style.display = 'block';
          msg.textContent = data.error || 'Unable to cancel. Please contact support.';
        }
      } catch(e) {
        btn.disabled = false;
        btn.textContent = 'Cancel Order';
        msg.style.display = 'block';
        msg.textContent = 'Something went wrong. Please try again.';
      }
    }

    async function cancelUnprepared(orderId) {
      if (!confirm('This will cancel your order with a full refund. A $15 penalty will be applied to the driver. Continue?')) return;
      const btn = document.getElementById('cancelUnpreparedBtn');
      const msg = document.getElementById('unpreparedMsg');
      btn.disabled = true;
      btn.textContent = 'Cancelling...';
      try {
        const res = await fetch(`/api/orders/${orderId}/cancel-unprepared`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({}) });
        const data = await res.json();
        msg.style.display = 'block';
        if (data.success) {
          btn.style.display = 'none';
          const cancelBtn = document.getElementById('cancelOrderBtn');
          if (cancelBtn) cancelBtn.style.display = 'none';
          msg.style.color = '#6daa45';
          msg.textContent = data.message || 'Order cancelled. Full refund issued.';
        } else {
          btn.disabled = false;
          btn.textContent = 'Driver arrived without proper equipment?';
          msg.style.color = '#dd6974';
          msg.textContent = data.error || 'Unable to cancel. Please contact support.';
        }
      } catch(e) {
        btn.disabled = false;
        btn.textContent = 'Driver arrived without proper equipment?';
        msg.style.display = 'block';
        msg.style.color = '#dd6974';
        msg.textContent = 'Something went wrong. Please try again.';
      }
    }
    </script>
  </div>

  <script>
    (function pollStatus() {
      const orderId = '<%= order.id %>';
      const locationCard = document.getElementById('driver-location-card');
      const locationTimeEl = document.getElementById('location-update-time');
      let pollCount = 0;

      function check() {
        fetch('/track/api/' + orderId)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.driver_location && locationCard && locationTimeEl) {
              locationCard.style.display = 'flex';
              var updated = new Date(data.driver_location.updated_at);
              var diff = Math.round((Date.now() - updated) / 1000);
              locationTimeEl.textContent = diff < 60
                ? 'Updated ' + diff + 's ago'
                : 'Updated ' + Math.round(diff / 60) + 'm ago';
            }
          })
          .catch(function() {})
          .finally(function() {
            if (++pollCount < 30) {
              setTimeout(check, 10000);
            }
          });
      }

      check();
    })();
  </script>
</body>
</html>