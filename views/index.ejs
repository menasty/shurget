  <meta name="description" content="Same-day pickup truck delivery for furniture, appliances, and oversized items. Book in 60 seconds. Delivered today by a vetted local driver.">
  <link rel="stylesheet" href="/css/theme.css">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
