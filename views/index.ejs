.business-card {
  background: #fff;
  border-radius: 14px;
  padding: 2rem 1.75rem;
  border: 1px solid rgba(0,0,0,.06);
  box-shadow: 0 2px 12px rgba(0,0,0,.04);
}
.business-card.highlight-card {
  background: #111;
  border-color: rgba(234,88,12,.3);
}
.business-icon { font-size: 2rem; margin-bottom: 1rem; }
.business-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: .75rem; color: #111; }
.business-card.highlight-card h3 { color: #fff; }
.business-card p { font-size: .875rem; color: #666; line-height: 1.7; margin-bottom: 1.25rem; }
.business-card.highlight-card p { color: rgba(255,255,255,.6); }
.btn-business {
  display: inline-block;
  padding: .75rem 1.5rem;
  background: #ea580c;
  color: #fff;
  border-radius: 8px;
  font-size: .875rem;
  font-weight: 700;
  text-decoration: none;
  transition: background .2s;
}
.btn-business:hover { background: #d14a00; }
.business-logos-label {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: #aaa;
  text-align: center;
  margin-bottom: 1.25rem;
}
.business-types {
  display: flex;
  flex-wrap: wrap;
  gap: .625rem;
  justify-content: center;
}
.biz-type {
  padding: .5rem 1rem;
  background: #fff;
  border-radius: 99px;
  font-size: .85rem;
  font-weight: 600;
  color: #444;
  border: 1px solid rgba(0,0,0,.08);
}

/* Final CTA */
.final-cta {
  background: linear-gradient(135deg, #ea580c 0%, #7c2d12 100%);
  text-align: center;
}
.cta-inner {
  max-width: 700px;
  margin: 0 auto;
  padding: 6rem 1.5rem;
}
.cta-headline {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(3rem, 7vw, 5.5rem);
  letter-spacing: .04em;
  color: #fff;
  margin-bottom: .75rem;
}
.cta-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,.75);
  margin-bottom: 2.5rem;
}
.cta-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}
.cta-actions .btn-hero-primary {
  background: #fff;
  color: #ea580c;
}
.cta-actions .btn-hero-primary:hover { background: #f5f5f5; }
.cta-actions .btn-hero-ghost {
  border-color: rgba(255,255,255,.35);
  color: rgba(255,255,255,.85);
}

/* Responsive */
@media (max-width: 768px) {
  .driver-inner { grid-template-columns: 1fr; }
  .driver-earnings-card { display: none; }
  .step-connector { display: none; }
  .steps-grid { flex-direction: column; }
  .trust-divider { display: none; }
  .trust-inner { gap: .5rem; }
  .problem-callout { flex-direction: column; gap: 1.5rem; }
}
</style>

<%- include('partials/footer') %>
</body>
</html>
