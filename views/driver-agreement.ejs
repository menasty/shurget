<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Driver Independent Contractor Agreement — Shurget</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:#0a0a0a;color:#f8f7f5;font-family:'DM Sans',sans-serif;min-height:100vh;line-height:1.65}

    /* ── Skip link ── */
    .skip-link{position:absolute;top:-9999px;left:1rem;background:#ea580c;color:#fff;padding:.5rem 1rem;
               border-radius:0 0 8px 8px;font-weight:700;z-index:1000}
    .skip-link:focus{top:0}

    /* ── Nav ── */
    .ag-nav{background:#111;border-bottom:3px solid #ea580c;padding:.875rem 1.5rem;
            display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:60}
    .ag-nav-logo{display:flex;align-items:center;gap:.6rem;text-decoration:none}
    .ag-nav-logo img{height:32px;width:auto}
    .ag-nav-logo span{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.12em;color:#fff}
    .ag-nav-label{font-size:.75rem;font-weight:700;color:rgba(255,255,255,.5);
                  text-transform:uppercase;letter-spacing:.08em}

    /* ── Hero ── */
    .ag-hero{background:#0a0a0a;position:relative;overflow:hidden;
             padding:clamp(3rem,7vw,5rem) clamp(1.5rem,5vw,4rem) 2.5rem}
    .ag-hero::before{content:'';position:absolute;top:-80px;right:-60px;width:500px;height:500px;
                     background:radial-gradient(ellipse,rgba(234,88,12,.12) 0%,transparent 65%);
                     pointer-events:none}
    .ag-hero-inner{max-width:820px;margin:0 auto;position:relative;
                   border-left:6px solid #ea580c;padding-left:clamp(1.25rem,3vw,2rem)}
    .p-eyebrow{display:inline-flex;align-items:center;gap:.5rem;margin-bottom:1rem;
               font-size:.78rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#ea580c}
    .p-eyebrow::before{content:'';display:block;width:24px;height:2px;background:#ea580c;flex-shrink:0}
    .ag-hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.2rem,6vw,3.4rem);
                letter-spacing:.06em;color:#fff;line-height:1.05;margin-bottom:.75rem}
    .ag-hero-sub{font-size:clamp(.9rem,2vw,1rem);color:rgba(255,255,255,.6);max-width:560px}
    .ag-meta{display:flex;gap:1.5rem;margin-top:1.25rem;flex-wrap:wrap}
    .ag-meta-item{font-size:.78rem;color:rgba(255,255,255,.45)}
    .ag-meta-item strong{color:rgba(255,255,255,.7)}

    /* ── Layout ── */
    .ag-wrap{max-width:820px;margin:0 auto;padding:2.5rem 1.5rem 5rem}

    /* ── Section headings ── */
    .ag-section{margin-bottom:2.5rem}
    .ag-section-title{font-family:'Bebas Neue',sans-serif;font-size:1.35rem;letter-spacing:.08em;
                      color:#ea580c;border-bottom:1px solid rgba(234,88,12,.25);padding-bottom:.5rem;
                      margin-bottom:1.1rem}
    .ag-section p{font-size:.92rem;color:rgba(255,255,255,.8);margin-bottom:.85rem}
    .ag-section ul,
    .ag-section ol{padding-left:1.4rem;margin-bottom:.85rem}
    .ag-section li{font-size:.92rem;color:rgba(255,255,255,.75);margin-bottom:.45rem;line-height:1.55}
    .ag-section strong{color:#fff}

    /* ── Callout box ── */
    .callout{border-radius:12px;padding:1.25rem 1.4rem;margin:1.4rem 0}
    .callout-orange{background:rgba(234,88,12,.08);border:1px solid rgba(234,88,12,.35)}
    .callout-green{background:rgba(34,197,94,.06);border:1px solid rgba(34,197,94,.25)}
    .callout-title{font-weight:700;font-size:.88rem;text-transform:uppercase;
                   letter-spacing:.07em;margin-bottom:.6rem}
    .callout-orange .callout-title{color:#ea580c}
    .callout-green .callout-title{color:#22c55e}
    .callout p{font-size:.88rem;color:rgba(255,255,255,.75);margin-bottom:.7rem}
    .callout p:last-child{margin-bottom:0}

    /* ── CTA buttons ── */
    .btn-callout{display:inline-flex;align-items:center;gap:.5rem;padding:.72rem 1.4rem;
                 border-radius:10px;font-weight:700;font-size:.88rem;text-decoration:none;
                 transition:background .2s,transform .1s;cursor:pointer}
    .btn-callout:hover{transform:translateY(-1px)}
    .btn-callout-orange{background:#b84000;color:#fff}
    .btn-callout-orange:hover{background:#9e3800}
    .btn-callout-green{background:rgba(34,197,94,.15);color:#22c55e;
                       border:1px solid rgba(34,197,94,.35)}
    .btn-callout-green:hover{background:rgba(34,197,94,.22)}

    /* ── Divider ── */
    .ag-divider{border:none;border-top:1px solid rgba(255,255,255,.07);margin:2rem 0}

    /* ── Already signed banner ── */
    .already-signed{background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.3);
                    border-radius:12px;padding:1.5rem 1.75rem;text-align:center;margin-bottom:2.5rem}
    .already-signed h2{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.08em;
                       color:#22c55e;margin-bottom:.5rem}
    .already-signed p{font-size:.9rem;color:rgba(255,255,255,.65)}

    /* ── Signature form ── */
    .sig-card{background:#111;border:1px solid rgba(255,255,255,.08);border-radius:16px;
              padding:2rem;margin-top:2.5rem}
    .sig-card h2{font-family:'Bebas Neue',sans-serif;font-size:1.7rem;letter-spacing:.08em;
                 color:#fff;margin-bottom:.5rem}
    .sig-card p.sub{font-size:.88rem;color:rgba(255,255,255,.5);margin-bottom:1.5rem}
    .form-group{margin-bottom:1.1rem}
    .form-group label{display:block;font-size:.82rem;font-weight:700;
                      text-transform:uppercase;letter-spacing:.06em;
                      color:rgba(255,255,255,.6);margin-bottom:.4rem}
    .form-group input[type="text"],
    .form-group input[type="email"]{width:100%;background:#1a1a1a;border:1px solid rgba(255,255,255,.12);
                                    border-radius:10px;padding:.72rem 1rem;color:#fff;font-size:.95rem;
                                    font-family:'DM Sans',sans-serif;transition:border-color .2s}
    .form-group input:focus{outline:none;border-color:#ea580c}
    .form-group input::placeholder{color:rgba(255,255,255,.25)}

    /* Checkbox row */
    .check-row{display:flex;align-items:flex-start;gap:.85rem;margin-bottom:1rem;
               background:#1a1a1a;border:1px solid rgba(255,255,255,.08);
               border-radius:10px;padding:.9rem 1rem}
    .check-row input[type="checkbox"]{width:18px;height:18px;flex-shrink:0;
                                      accent-color:#ea580c;margin-top:.1rem;cursor:pointer}
    .check-row label{font-size:.88rem;color:rgba(255,255,255,.75);cursor:pointer;line-height:1.5}
    .check-row label a{color:#ea580c;text-decoration:underline}

    /* Legal disclaimer */
    .sig-legal{font-size:.78rem;color:rgba(255,255,255,.4);line-height:1.55;
               margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid rgba(255,255,255,.07)}

    /* Submit button */
    .btn-sign{display:block;width:100%;margin-top:1.4rem;padding:.9rem 1.5rem;
              background:#b84000;color:#fff;border:none;border-radius:12px;
              font-family:'DM Sans',sans-serif;font-size:1rem;font-weight:700;
              cursor:pointer;transition:background .2s,transform .1s;text-align:center}
    .btn-sign:hover{background:#9e3800}
    .btn-sign:active{transform:scale(.99)}
    .btn-sign:disabled{background:#333;color:rgba(255,255,255,.3);cursor:not-allowed}

    /* Error / success messages */
    .form-error{color:#f87171;font-size:.82rem;margin-top:.4rem;display:none}
    .form-error.show{display:block}

    /* ── Footer ── */
    .ag-footer{text-align:center;padding:2rem 1rem;font-size:.78rem;
               color:rgba(255,255,255,.3);border-top:1px solid rgba(255,255,255,.06)}

    @media(max-width:600px){
      .ag-meta{gap:1rem}
      .sig-card{padding:1.25rem}
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <nav class="ag-nav" aria-label="Site navigation">
    <a href="/" class="ag-nav-logo">
      <img src="/images/shurget-logo-nav.png" alt="Shurget" onerror="this.style.display='none'">
      <span>SHURGET</span>
    </a>
    <span class="ag-nav-label">Driver Agreement</span>
  </nav>

  <!-- Hero -->
  <section class="ag-hero" aria-labelledby="ag-hero-title">
    <div class="ag-hero-inner">
      <div class="p-eyebrow">Independent Contractor Agreement</div>
      <h1 id="ag-hero-title">Driver Service<br>Agreement</h1>
      <p class="ag-hero-sub">
        Read this agreement carefully before driving with Shurget. By signing, you confirm
        you understand and accept these terms as an independent contractor.
      </p>
      <div class="ag-meta">
        <span class="ag-meta-item"><strong>Effective:</strong> Upon electronic signature</span>
        <span class="ag-meta-item"><strong>Version:</strong> 1.0 — June 2026</span>
        <span class="ag-meta-item"><strong>Governing law:</strong> State of Colorado</span>
      </div>
    </div>
  </section>

  <main class="ag-wrap" id="main-content">

    <% if (typeof alreadySigned !== 'undefined' && alreadySigned) { %>
    <!-- Already signed banner -->
    <div class="already-signed" role="status">
      <h2>Agreement on File</h2>
      <p>Your signature was recorded on <strong><%= signedAt %></strong>. No further action is needed.</p>
      <p style="margin-top:.5rem">
        <a href="/driver/jobs" style="color:#ea580c;font-weight:700;text-decoration:underline">
          Go to Driver Portal &rarr;
        </a>
      </p>
    </div>
    <% } %>

    <!-- ── 1. Parties ── -->
    <div class="ag-section">
      <div class="ag-section-title">1. Parties to This Agreement</div>
      <p>
        This Independent Contractor Agreement ("Agreement") is entered into between
        <strong>Shurget LLC</strong>, a Colorado limited liability company ("Company," "Platform,"
        or "Shurget"), and the individual executing this Agreement ("Driver," "you," or
        "Contractor"). This Agreement governs all driving and delivery services performed
        through the Shurget platform.
      </p>
    </div>

    <!-- ── 2. Independent Contractor Status ── -->
    <div class="ag-section">
      <div class="ag-section-title">2. Independent Contractor Status</div>
      <p>
        <strong>You are not an employee of Shurget.</strong> You are an independent contractor.
        Nothing in this Agreement shall be construed to create an employment relationship,
        partnership, joint venture, agency, franchise, or sales representative relationship
        between you and Shurget.
      </p>
      <ul>
        <li>You retain the right to perform services for other platforms, companies, or customers simultaneously, subject to Section 4.</li>
        <li>You set your own hours and availability. Shurget does not guarantee a minimum number of jobs or earnings.</li>
        <li>You supply and maintain your own vehicle, tools, fuel, and equipment at your sole expense.</li>
        <li>You have the right to accept or decline any job offered through the platform without penalty.</li>
        <li>Shurget does not direct or control the manner in which you perform deliveries, only the outcome specifications (delivery confirmation, item condition).</li>
        <li>You may hire assistants or helpers for a job at your own cost and responsibility, provided they meet the same insurance requirements below.</li>
      </ul>
    </div>

    <!-- ── 3. 1099 & Tax Obligations ── -->
    <div class="ag-section">
      <div class="ag-section-title">3. Tax Obligations — 1099 Independent Contractor</div>
      <p>
        As an independent contractor, <strong>you are solely responsible for all federal, state,
        and local taxes</strong> on income earned through the Shurget platform. Shurget will not
        withhold income tax, Social Security, Medicare, or any other taxes from your payments.
      </p>
      <ul>
        <li>
          <strong>IRS Form 1099-NEC:</strong> If your total earnings through Shurget equal or
          exceed <strong>$600 in a calendar year</strong>, Shurget will issue you a Form 1099-NEC
          by January 31 of the following year. Earnings below $600 are still taxable income and
          must be reported by you.
        </li>
        <li>
          <strong>Self-Employment Tax:</strong> You are responsible for paying self-employment tax
          (currently 15.3% on net earnings up to the Social Security wage base) in addition to
          federal and state income tax.
        </li>
        <li>
          <strong>Quarterly Estimated Taxes:</strong> The IRS generally requires self-employed
          individuals to pay estimated taxes quarterly (April 15, June 15, September 15, January 15).
          Failure to do so may result in underpayment penalties.
        </li>
        <li>
          <strong>Deductible Business Expenses:</strong> As a contractor, you may be able to deduct
          vehicle mileage (IRS standard mileage rate), fuel, maintenance, phone, and other
          ordinary business expenses. Consult a qualified tax professional.
        </li>
        <li>
          <strong>W-9 Requirement:</strong> You agree to provide Shurget with a completed IRS
          Form W-9 (Taxpayer Identification Number and Certification) before receiving your first
          payout. Failure to provide a W-9 may result in backup withholding at the applicable rate.
        </li>
      </ul>
      <p>
        Shurget strongly recommends consulting a licensed tax professional to understand your
        individual obligations. Shurget is not responsible for any tax liability, penalties, or
        interest you incur.
      </p>
    </div>

    <!-- ── 4. Liability & Indemnification ── -->
    <div class="ag-section">
      <div class="ag-section-title">4. Liability &amp; Indemnification</div>
      <p>
        <strong>You assume full responsibility and liability</strong> for all activities performed
        in connection with deliveries made through the Shurget platform, including but not limited
        to property damage, personal injury, traffic violations, and accidents.
      </p>
      <ul>
        <li>
          <strong>Property Damage:</strong> You are solely liable for any damage to a customer's
          property, cargo, or real estate that occurs during pickup, transport, or delivery.
          Shurget's platform fee does not include any cargo or property insurance on the Company's
          behalf.
        </li>
        <li>
          <strong>Personal Injury:</strong> You are solely liable for any bodily injury to
          yourself, your helpers, customers, or third parties that arises during the performance
          of delivery services.
        </li>
        <li>
          <strong>Vehicle Operation:</strong> You are solely responsible for any accidents,
          traffic violations, citations, towing fees, or vehicle damage that occurs while you
          are performing or traveling to/from a delivery.
        </li>
        <li>
          <strong>Indemnification:</strong> You agree to indemnify, defend, and hold harmless
          Shurget LLC, its officers, members, employees, and agents from and against any claims,
          damages, losses, liabilities, costs, and expenses (including reasonable attorneys' fees)
          arising out of or related to: (a) your performance of services; (b) your breach of this
          Agreement; (c) your negligence or willful misconduct; or (d) your violation of any
          applicable law or regulation.
        </li>
        <li>
          <strong>Limitation of Shurget Liability:</strong> To the maximum extent permitted by
          applicable law, Shurget's total aggregate liability to you for any cause of action
          shall not exceed the total platform fees earned by Shurget on orders completed by you
          in the thirty (30) days preceding the claim.
        </li>
        <li>
          <strong>No Warranty:</strong> Shurget provides the platform "as is" and makes no
          warranty regarding the volume of jobs, earnings potential, or continuity of service.
        </li>
      </ul>
    </div>

    <!-- ── 5. Insurance Requirements ── -->
    <div class="ag-section">
      <div class="ag-section-title">5. Insurance Requirements</div>
      <p>
        <strong>Active, valid insurance coverage is a prerequisite for driving with Shurget.</strong>
        You must maintain all required coverage for the entire period you are active on the platform.
        Lapse in coverage is grounds for immediate deactivation.
      </p>
      <ul>
        <li>
          <strong>Auto Liability Insurance:</strong> You must carry personal or commercial
          auto liability insurance that meets or exceeds the minimum limits required by the State
          of Colorado (currently $25,000/$50,000 bodily injury / $15,000 property damage). Commercial
          auto coverage is strongly recommended if you use your vehicle primarily for deliveries.
        </li>
        <li>
          <strong>General Liability Insurance:</strong> You must maintain commercial general
          liability (CGL) insurance with a minimum limit of <strong>$300,000 per occurrence</strong>
          covering bodily injury and property damage arising from your delivery operations.
        </li>
        <li>
          <strong>Cargo / Property Damage Coverage:</strong> If your auto policy does not include
          coverage for property in your care, custody, or control (customer items being transported),
          you must obtain a separate cargo or inland marine policy. Minimum recommended: $10,000
          per occurrence.
        </li>
        <li>
          <strong>Proof of Insurance:</strong> You must provide current certificates of insurance
          at application and upon renewal. Shurget reserves the right to request updated proof at
          any time.
        </li>
      </ul>

      <!-- Insurance callout -->
      <div class="callout callout-orange">
        <div class="callout-title">Need Insurance Coverage?</div>
        <p>
          If you do not currently have the required general liability or property damage coverage,
          Next Insurance offers affordable, fast policies designed specifically for independent
          contractors and gig workers. Get a quote in minutes — no broker required.
        </p>
        <a href="https://refer.nextinsurance.com/W5sAxsx"
           target="_blank"
           rel="noopener noreferrer"
           class="btn-callout btn-callout-orange">
          Get Coverage with Next Insurance &rarr;
        </a>
      </div>
    </div>

    <!-- ── 6. Driver Requirements ── -->
    <div class="ag-section">
      <div class="ag-section-title">6. Driver Eligibility Requirements</div>
      <p>You represent and warrant that at all times while active on the platform:</p>
      <ul>
        <li>You are at least 21 years of age.</li>
        <li>You hold a valid, unexpired driver's license issued by a U.S. state.</li>
        <li>You own or have lawful use of a vehicle capable of safely transporting the item types you accept.</li>
        <li>You have passed and continue to meet the background check criteria set by Shurget and its third-party screening vendor.</li>
        <li>Your vehicle is registered, inspected, and mechanically fit for commercial use.</li>
        <li>You are legally authorized to work in the United States.</li>
        <li>You have no unresolved DUIs, reckless driving convictions, or at-fault accidents involving injury within the past five (5) years.</li>
      </ul>
    </div>

    <!-- ── 7. Platform Rules ── -->
    <div class="ag-section">
      <div class="ag-section-title">7. Platform Conduct &amp; Rules</div>
      <ul>
        <li>You must arrive at pickup locations sober, professional, and on time.</li>
        <li>You must handle all customer property with reasonable care; treat all items as if they were your own.</li>
        <li>You may not subcontract jobs to unlicensed or uninsured third parties without written consent from Shurget.</li>
        <li>You may not use the Shurget platform to solicit direct business from customers outside of the platform in circumvention of the platform fee.</li>
        <li>Harassment, discrimination, or threatening behavior toward customers, other drivers, or Shurget personnel is grounds for immediate and permanent deactivation.</li>
        <li>You must maintain a minimum customer rating as communicated by Shurget (currently 4.0 / 5.0 rolling average) to remain eligible for jobs.</li>
        <li>You must respond to dispatched job requests within the timeframe shown in the driver portal. Repeated non-responses may result in reduced job visibility.</li>
      </ul>
    </div>

    <!-- ── 8. Payment Terms ── -->
    <div class="ag-section">
      <div class="ag-section-title">8. Compensation &amp; Payment</div>
      <p>
        Your earnings for each completed delivery are calculated as
        <strong>80% of the total customer order value</strong> (base rate + distance charge +
        applicable helper fees). The remaining 20% is retained by Shurget as its platform fee.
      </p>
      <ul>
        <li>Payments are processed via Stripe Connect to your linked bank account. You must complete Stripe's identity verification to receive payouts.</li>
        <li>Payouts are issued <strong>weekly, every Friday</strong>, directly to your linked bank account via Stripe Connect. Shurget may offer instant payout options at an additional processing fee.</li>
        <li>You are responsible for any Stripe fees, bank transfer fees, or taxes associated with receiving payment.</li>
        <li>Disputed orders may have their payout held pending resolution per Shurget's dispute policy.</li>
        <li>Shurget reserves the right to adjust the platform fee percentage with 14 days written notice delivered to your registered email address.</li>
      </ul>
    </div>

    <!-- ── 9. Termination ── -->
    <div class="ag-section">
      <div class="ag-section-title">9. Termination</div>
      <p>
        Either party may terminate this Agreement at any time, for any reason, with or without notice.
        Shurget may immediately deactivate your account without notice for: insurance lapse, fraudulent
        activity, customer harm, platform abuse, or material breach of this Agreement. Upon termination,
        any earned but unpaid amounts for completed deliveries will be paid out on the next regular
        payment cycle.
      </p>
    </div>

    <!-- ── 10. Dispute Resolution ── -->
    <div class="ag-section">
      <div class="ag-section-title">10. Dispute Resolution &amp; Governing Law</div>
      <p>
        Any dispute arising from this Agreement shall first be submitted to good-faith negotiation
        between the parties. If unresolved within 30 days, disputes shall be resolved by binding
        arbitration administered under the rules of the American Arbitration Association (AAA) in
        Denver, Colorado, before a single arbitrator. <strong>You waive any right to a jury trial
        or class action participation</strong> with respect to any dispute arising under this
        Agreement. This Agreement shall be governed by the laws of the State of Colorado without
        regard to its conflict of law provisions.
      </p>
    </div>

    <!-- ── 11. Miscellaneous ── -->
    <div class="ag-section">
      <div class="ag-section-title">11. Miscellaneous</div>
      <ul>
        <li><strong>Entire Agreement:</strong> This Agreement constitutes the entire agreement between you and Shurget with respect to its subject matter and supersedes all prior discussions.</li>
        <li><strong>Severability:</strong> If any provision is found unenforceable, the remaining provisions shall remain in full force.</li>
        <li><strong>Modification:</strong> Shurget may update this Agreement with 14 days notice. Continued use of the platform after the effective date of any update constitutes acceptance.</li>
        <li><strong>No Waiver:</strong> Shurget's failure to enforce any provision shall not constitute a waiver of its right to enforce it in the future.</li>
      </ul>
    </div>

    <hr class="ag-divider">

    <!-- ── Fuel Savings Callout ── -->
    <div class="callout callout-green">
      <div class="callout-title">Save on Every Gallon — Upside Cash Back</div>
      <p>
        Fuel is your biggest variable cost as a delivery driver. Upside gives you cash back
        on gas purchases at thousands of stations nationwide — no membership fees, no gimmicks.
        Drivers using Upside report saving an average of $0.25–$0.45 per gallon.
      </p>
      <a href="https://upside.app.link/shurget"
         target="_blank"
         rel="noopener noreferrer"
         class="btn-callout btn-callout-green"
         id="upside-link">
        Get Cash Back on Gas with Upside &rarr;
      </a>
    </div>

    <hr class="ag-divider">

    <% if (typeof alreadySigned === 'undefined' || !alreadySigned) { %>
    <!-- ── Signature Form ── -->
    <div class="sig-card" id="sign-agreement">
      <h2>Sign This Agreement</h2>
      <p class="sub">
        Type your full legal name and email exactly as they appear on your application,
        then check each box to confirm your understanding. Your electronic signature carries
        the same legal weight as a handwritten signature.
      </p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);
                    border-radius:10px;padding:.9rem 1.1rem;margin-bottom:1.25rem;
                    color:#f87171;font-size:.88rem;">
          <%= error %>
        </div>
      <% } %>

      <form action="/drive/agreement" method="POST" id="agreementForm" novalidate>
        <input type="hidden" name="applicationId" value="<%= typeof applicationId !== 'undefined' ? applicationId : '' %>">

        <div class="form-group">
          <label for="sig-name">Full Legal Name <span style="color:#ea580c">*</span></label>
          <input type="text" id="sig-name" name="signatureName"
                 placeholder="As it appears on your application"
                 autocomplete="name" required
                 value="<%= typeof prefillName !== 'undefined' ? prefillName : '' %>">
          <div class="form-error" id="err-name">Please enter your full legal name.</div>
        </div>

        <div class="form-group">
          <label for="sig-email">Email Address <span style="color:#ea580c">*</span></label>
          <input type="email" id="sig-email" name="email"
                 placeholder="Same email used in your driver application"
                 autocomplete="email" required
                 value="<%= typeof prefillEmail !== 'undefined' ? prefillEmail : '' %>">
          <div class="form-error" id="err-email">Please enter the email address from your driver application.</div>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-contractor" name="chkContractor" required>
          <label for="chk-contractor">
            I understand and agree that I am an <strong>independent contractor</strong>, not an
            employee of Shurget, and that I am solely responsible for my own taxes, expenses,
            and compliance with applicable laws.
          </label>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-tax" name="chkTax" required>
          <label for="chk-tax">
            I understand that Shurget will not withhold taxes from my earnings. I am responsible
            for paying all applicable <strong>self-employment, federal, and state taxes</strong>
            and will provide a completed IRS Form W-9 before receiving my first payout.
          </label>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-liability" name="chkLiability" required>
          <label for="chk-liability">
            I accept full <strong>personal liability</strong> for property damage, personal injury,
            and accidents that occur during deliveries, and I agree to indemnify and hold Shurget
            harmless as described in Section 4 of this Agreement.
          </label>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-insurance" name="chkInsurance" required>
          <label for="chk-insurance">
            I confirm that I currently hold <strong>valid auto liability insurance</strong> and will
            obtain general liability and property/cargo coverage as required in Section 5 before
            accepting my first delivery. I understand that lapse in required coverage will result
            in immediate platform deactivation.
          </label>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-arbitration" name="chkArbitration" required>
          <label for="chk-arbitration">
            I have read and understand the <strong>dispute resolution and arbitration clause</strong>
            in Section 10, including the waiver of jury trial and class action rights.
          </label>
        </div>

        <div class="check-row">
          <input type="checkbox" id="chk-full" name="chkFull" required>
          <label for="chk-full">
            I have read this Agreement in full and agree to all of its terms and conditions.
            I confirm that all information I have provided is truthful and accurate.
          </label>
        </div>

        <div class="sig-legal">
          By clicking "Sign &amp; Submit Agreement" below, you are electronically signing this
          Independent Contractor Agreement. Your full name, email address, IP address, and
          timestamp will be recorded as your electronic signature and maintained by Shurget LLC
          in accordance with the Electronic Signatures in Global and National Commerce Act
          (E-SIGN Act, 15 U.S.C. &sect; 7001) and the Colorado Uniform Electronic Transactions Act.
        </div>

        <div class="form-error show" id="err-checkboxes" style="display:none;margin-top:1rem">
          Please check all boxes above before submitting.
        </div>

        <button type="submit" class="btn-sign" id="submitBtn">
          Sign &amp; Submit Agreement
        </button>
      </form>
    </div>
    <% } %>

  </main>

  <footer class="ag-footer">
    <p>&copy; <%= new Date().getFullYear() %> Shurget LLC &mdash; Castle Rock, Colorado</p>
    <p style="margin-top:.3rem">Questions? Email <a href="mailto:support@shurget.com" style="color:#ea580c">support@shurget.com</a></p>
  </footer>

