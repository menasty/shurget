<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dispatch — Shurget Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #0a0a0a; color: #f8f7f5; font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    .admin-topnav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,.92); backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,.07);
      height: 58px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 clamp(1.25rem,4vw,2.5rem);
    }
    .admin-topnav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .12em; color: #fff; text-decoration: none; display: flex; align-items: center; gap: .5rem; }
    .admin-topnav-logo span { color: #ea580c; }
    .admin-topnav-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(234,88,12,.15); color: #ea580c; border: 1px solid rgba(234,88,12,.3); border-radius: 4px; padding: .15rem .5rem; }
    .tn-btn { font-size: .78rem; font-weight: 600; text-decoration: none; padding: .4rem .9rem; border-radius: 6px; border: none; cursor: pointer; transition: background .2s; font-family: 'DM Sans', sans-serif; }
    .tn-btn-ghost { background: rgba(255,255,255,.07); color: rgba(255,255,255,.65); }
    .tn-btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; }
    .tn-btn-primary { background: #b84000; color: #fff; }
    .tn-btn-primary:hover { background: #9e3800; }

    .admin-layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 58px); }
    @media (max-width: 768px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { display: flex; overflow-x: auto; padding: .75rem; gap: .4rem; border-right: none; border-bottom: 1px solid rgba(255,255,255,.07); } .sidebar-section-label { display: none; } }
    .admin-sidebar { background: #111; border-right: 1px solid rgba(255,255,255,.07); padding: 1.25rem .75rem; display: flex; flex-direction: column; gap: .15rem; }
    .sidebar-section-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.3); padding: .9rem .6rem .35rem; }
    .sidebar-link { display: flex; align-items: center; gap: .6rem; padding: .52rem .7rem; border-radius: 7px; text-decoration: none; color: rgba(255,255,255,.55); font-size: .82rem; font-weight: 500; transition: all .18s; white-space: nowrap; }
    .sidebar-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
    .sidebar-link.active { background: rgba(184,64,0,.18); color: #ea580c; font-weight: 600; }
    .sidebar-icon { font-size: 1rem; flex-shrink: 0; }
    .admin-main { padding: clamp(1.5rem,4vw,2.5rem); overflow-x: hidden; }

    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: .06em; color: #fff; margin: 0 0 .25rem; }
    .page-subtitle { font-size: .88rem; color: rgba(255,255,255,.45); margin: 0 0 1.75rem; }

    .card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.5rem; }
    .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; }

    .data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .data-table th { background: #111; color: rgba(255,255,255,.45); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; padding: .65rem 1rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,.07); }
    .data-table td { padding: .75rem 1rem; border-bottom: 1px solid rgba(255,255,255,.04); color: #f8f7f5; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: rgba(255,255,255,.03); }
    .table-wrap { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; overflow: hidden; }

    .badge { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: .25rem .6rem; border-radius: 5px; }
    .badge-green  { background: rgba(22,163,74,.15);  color: #4ade80; border: 1px solid rgba(22,163,74,.25); }
    .badge-orange { background: rgba(234,88,12,.15);  color: #ea580c; border: 1px solid rgba(234,88,12,.25); }
    .badge-red    { background: rgba(239,68,68,.15);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .badge-gray   { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.1); }
    .badge-blue   { background: rgba(59,130,246,.15); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }

    .btn { display: inline-flex; align-items: center; gap: .4rem; font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600; padding: .5rem 1rem; border-radius: 7px; border: none; cursor: pointer; text-decoration: none; transition: all .2s; }
    .btn-primary { background: #b84000; color: #fff; }
    .btn-primary:hover { background: #9e3800; }
    .btn-ghost { background: rgba(255,255,255,.06); color: rgba(255,255,255,.65); border: 1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { background: rgba(255,255,255,.1); color: #fff; }
    .btn-danger { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .btn-danger:hover { background: rgba(239,68,68,.25); }
    .btn-sm { padding: .4rem .85rem; font-size: .78rem; }

    .form-input { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; transition: border-color .2s; }
    .form-input:focus { border-color: #b84000; }
    .form-select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; }

    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.75rem; }
    .metric-card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.25rem 1.5rem; }
    .metric-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin: 0 0 .4rem; }
    .metric-value { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: .04em; color: #fff; line-height: 1; margin: 0; }
    .metric-sub { font-size: .75rem; color: rgba(255,255,255,.35); margin: .3rem 0 0; }

    .alert { border-radius: 9px; padding: .75rem 1.1rem; font-size: .88rem; margin-bottom: 1.25rem; }
    .alert-success { background: rgba(22,163,74,.12); border: 1px solid rgba(22,163,74,.25); color: #4ade80; }
    .alert-error { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25); color: #f87171; }

    /* Section headers */
    .section { margin-bottom: 2.25rem; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.35rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; display: flex; align-items: center; gap: .55rem; }
    .section-count { background: #b84000; color: #fff; border-radius: 99px; font-size: .72rem; font-weight: 700; padding: .1rem .6rem; font-family: 'DM Sans', sans-serif; }

    /* Driver availability chips */
    .driver-avail-grid { display: flex; flex-wrap: wrap; gap: .75rem; }
    .driver-chip { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 10px; padding: .75rem 1rem; display: flex; align-items: center; gap: .75rem; min-width: 200px; }
    .driver-chip-avatar { width: 36px; height: 36px; border-radius: 50%; background: #b84000; color: #fff; font-weight: 700; font-size: .85rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .driver-chip-info .chip-name { font-weight: 600; font-size: .88rem; color: #f8f7f5; margin-bottom: .1rem; }
    .driver-chip-info .chip-meta { font-size: .78rem; color: rgba(255,255,255,.45); }
    .driver-chip-badge { margin-left: auto; }

    /* Empty state */
    .empty-state { text-align: center; padding: 3rem 1rem; color: rgba(255,255,255,.45); }
    .empty-state-icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h2 { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: #fff; margin-bottom: .5rem; letter-spacing: .04em; }
    .empty-state p { font-size: .9rem; }

    /* Cell labels used inside table-wrap rows */
    .cell-label { font-size: .68rem; text-transform: uppercase; letter-spacing: .09em; color: rgba(255,255,255,.35); margin-bottom: .25rem; display: block; }
    .cell-value { font-size: .86rem; color: #f8f7f5; font-weight: 500; line-height: 1.4; }
    .cell-value.muted { color: rgba(255,255,255,.45); font-weight: 400; }
    .order-id-badge { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 4px; padding: .25rem .5rem; font-size: .8rem; font-weight: 700; color: #f8f7f5; font-family: monospace; }
    .price { font-weight: 700; color: #f8f7f5; font-size: 1rem; }

    .dispatch-row { display: grid; padding: 1rem 1.25rem; align-items: start; gap: 1rem; border-bottom: 1px solid rgba(255,255,255,.06); }
    .dispatch-row:last-child { border-bottom: none; }
    .dispatch-row-pending { grid-template-columns: 90px 1fr 1fr 1fr 90px auto; }
    .dispatch-row-active { grid-template-columns: 90px 1fr 1fr 1fr 90px auto; }
    .dispatch-row-recent { grid-template-columns: 90px 1fr 1fr 1fr 90px; }
    @media (max-width: 768px) { .dispatch-row-pending, .dispatch-row-active, .dispatch-row-recent { grid-template-columns: 1fr 1fr; } }

    .action-form { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }
  </style>
</head>
<body>

  <!-- Top Nav -->
  <header class="admin-topnav">
    <a href="/admin" class="admin-topnav-logo">SHUR<span>GET</span> <span class="admin-topnav-badge">Admin</span></a>
    <div style="display:flex;align-items:center;gap:.65rem;">
      <a href="/admin" class="tn-btn tn-btn-ghost">← Dashboard</a>
      <a href="/admin/logout" class="tn-btn tn-btn-primary">Logout</a>
    </div>
  </header>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-section-label">Operations</div>
      <a href="/admin/dispatch" class="sidebar-link active"><span class="sidebar-icon">🚛</span> Dispatch</a>
      <a href="/admin/bookings" class="sidebar-link"><span class="sidebar-icon">📋</span> Bookings</a>
      <a href="/admin/drivers" class="sidebar-link"><span class="sidebar-icon">🧑‍✈️</span> Drivers</a>
      <div class="sidebar-section-label">Analytics</div>
      <a href="/admin/metrics" class="sidebar-link"><span class="sidebar-icon">📊</span> Metrics</a>
      <a href="/admin/ratings" class="sidebar-link"><span class="sidebar-icon">⭐</span> Ratings</a>
      <a href="/admin/attribution" class="sidebar-link"><span class="sidebar-icon">🔗</span> Attribution</a>
      <div class="sidebar-section-label">Platform</div>
      <a href="/admin/partners" class="sidebar-link"><span class="sidebar-icon">🤝</span> Partners</a>
      <a href="/admin/disputes" class="sidebar-link"><span class="sidebar-icon">⚖️</span> Disputes</a>
      <a href="/admin/surge" class="sidebar-link"><span class="sidebar-icon">⚡</span> Surge</a>
    </aside>

    <main class="admin-main">
      <h1 class="page-title">Dispatch</h1>
      <p class="page-subtitle">Manage driver assignments, active deliveries, and completed orders.</p>

      <!-- Flash alerts -->
      <% if (typeof assigned !== 'undefined' && assigned) { %>
        <div class="alert alert-success">Driver assigned successfully.</div>
      <% } %>
      <% if (typeof delivered !== 'undefined' && delivered) { %>
        <div class="alert alert-success">Order marked as delivered.</div>
      <% } %>
      <% if (typeof cancelled !== 'undefined' && cancelled) { %>
        <div class="alert alert-error">Order has been cancelled.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error === 'missing') { %>
        <div class="alert alert-error">Please select a driver before assigning.</div>
      <% } %>

      <!-- Metric bar -->
      <div class="metric-grid">
        <div class="metric-card">
          <p class="metric-label">Active Orders</p>
          <p class="metric-value"><%= pending.length + active.length %></p>
          <p class="metric-sub">Pending + in-flight</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Unassigned Orders</p>
          <p class="metric-value" style="color:#ea580c;"><%= pending.length %></p>
          <p class="metric-sub">Awaiting a driver</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Drivers Online</p>
          <p class="metric-value"><%= drivers.length %></p>
          <p class="metric-sub"><%= drivers.length - active.length >= 0 ? drivers.length - active.filter(a => drivers.some(d => d.id === a.driver_id)).length : 0 %> idle</p>
        </div>
      </div>

      <!-- Driver Availability -->
      <div class="section">
        <div class="section-title">
          <span>🚚</span> Driver Availability
          <% if (drivers.length > 0) { %>
            <span class="section-count"><%= drivers.length %></span>
          <% } %>
        </div>
        <% if (drivers.length === 0) { %>
          <div class="table-wrap">
            <div class="empty-state">
              <div class="empty-state-icon">🚚</div>
              <h2>No active drivers</h2>
              <p>Approve driver applications in the Drivers tab to see them here.</p>
            </div>
          </div>
        <% } else { %>
          <div class="driver-avail-grid">
            <% for (const driver of drivers) { %>
              <% const isBusy = active.some(a => a.driver_id === driver.id); %>
              <div class="driver-chip">
                <div class="driver-chip-avatar"><%= driver.name.charAt(0).toUpperCase() %></div>
                <div class="driver-chip-info">
                  <div class="chip-name"><%= driver.name %></div>
                  <div class="chip-meta"><%= driver.vehicle_type %> · 📍 <%= driver.city %></div>
                </div>
                <span class="driver-chip-badge badge <%= isBusy ? 'badge-orange' : 'badge-green' %>">
                  <%= isBusy ? 'On Job' : 'Idle' %>
                </span>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Pending Dispatches -->
      <div class="section">
        <div class="section-title">
          <span>⏳</span> Pending Dispatches
          <% if (pending.length > 0) { %>
            <span class="section-count"><%= pending.length %></span>
          <% } %>
        </div>
        <% if (pending.length === 0) { %>
          <div class="table-wrap">
            <div class="empty-state">
              <div class="empty-state-icon">✅</div>
              <h2>All clear</h2>
              <p>No orders waiting for a driver.</p>
            </div>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <% for (const order of pending) { %>
              <div class="dispatch-row dispatch-row-pending">
                <div>
                  <span class="cell-label">Order</span>
                  <span class="order-id-badge">#<%= order.id %></span>
                  <div class="cell-value muted" style="margin-top:0.3rem; font-size:0.78rem;">
                    <%= new Date(order.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) %>
                  </div>
                </div>
                <div>
                  <span class="cell-label">Pickup</span>
                  <div class="cell-value"><%= order.pickup_address %></div>
                </div>
                <div>
                  <span class="cell-label">Dropoff</span>
                  <div class="cell-value"><%= order.dropoff_address %></div>
                </div>
                <div>
                  <span class="cell-label">Customer</span>
                  <div class="cell-value"><%= order.customer_name || '—' %></div>
                  <% if (order.customer_phone) { %>
                    <div class="cell-value muted" style="font-size:0.78rem;"><%= order.customer_phone %></div>
                  <% } %>
                </div>
                <div>
                  <span class="cell-label">Price</span>
                  <span class="price">$<%= Number(order.price_total).toFixed(2) %></span>
                </div>
                <div>
                  <% if (drivers.length > 0) { %>
                    <form class="action-form" method="post" action="/admin/dispatch/<%= order.id %>/assign">
                      <select name="driverId" class="form-select" required>
                        <option value="">Select driver…</option>
                        <% for (const driver of drivers) { %>
                          <option value="<%= driver.id %>"><%= driver.name %> · <%= driver.city %></option>
                        <% } %>
                      </select>
                      <input type="hidden" name="driverName" value="">
                      <button type="submit" class="btn btn-primary btn-sm">Assign</button>
                    </form>
                  <% } else { %>
                    <span class="cell-value muted">No drivers</span>
                  <% } %>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Active Dispatches -->
      <div class="section">
        <div class="section-title">
          <span>🚛</span> Active Dispatches
          <% if (active.length > 0) { %>
            <span class="section-count"><%= active.length %></span>
          <% } %>
        </div>
        <% if (active.length === 0) { %>
          <div class="table-wrap">
            <div class="empty-state">
              <div class="empty-state-icon">🚛</div>
              <h2>No active deliveries</h2>
              <p>Assigned orders will appear here.</p>
            </div>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <% for (const order of active) { %>
              <div class="dispatch-row dispatch-row-active">
                <div>
                  <span class="cell-label">Order</span>
                  <span class="order-id-badge">#<%= order.id %></span>
                </div>
                <div>
                  <span class="cell-label">Driver</span>
                  <div class="cell-value"><%= order.driver_name || '—' %></div>
                  <% if (order.driver_phone) { %>
                    <div class="cell-value muted" style="font-size:0.78rem;"><a href="tel:<%= order.driver_phone %>" style="color:inherit;"><%= order.driver_phone %></a></div>
                  <% } %>
                </div>
                <div>
                  <span class="cell-label">Route</span>
                  <div class="cell-value" style="font-size:0.82rem;">
                    <div><%= order.pickup_address %></div>
                    <div style="color:rgba(255,255,255,.45);margin-top:0.15rem;">→ <%= order.dropoff_address %></div>
                  </div>
                </div>
                <div>
                  <span class="cell-label">Customer</span>
                  <div class="cell-value"><%= order.customer_name || '—' %></div>
                </div>
                <div>
                  <span class="cell-label">Status</span>
                  <% const activeBadge = order.status === 'delivered' ? 'badge-green' : (order.status === 'assigned' ? 'badge-blue' : (order.status === 'cancelled' ? 'badge-red' : 'badge-orange')); %>
                  <span class="badge <%= activeBadge %>"><%= order.status.replace('_', ' ') %></span>
                  <% if (order.eta_minutes) { %>
                    <div class="cell-value muted" style="font-size:0.78rem;margin-top:0.2rem;">
                      ETA: <%= order.eta_minutes %> min
                    </div>
                  <% } %>
                </div>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                  <form method="post" action="/admin/dispatch/<%= order.id %>/deliver">
                    <button type="submit" class="btn btn-primary btn-sm">Delivered</button>
                  </form>
                  <form method="post" action="/admin/dispatch/<%= order.id %>/cancel" onsubmit="return confirm('Cancel order #<%= order.id %>?');">
                    <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                  </form>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

      <!-- Recent Completed -->
      <div class="section">
        <div class="section-title">
          <span>📋</span> Recent Completed
        </div>
        <% if (recent.length === 0) { %>
          <div class="table-wrap">
            <div class="empty-state">
              <div class="empty-state-icon">📋</div>
              <h2>No completed orders yet</h2>
            </div>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <% for (const order of recent) { %>
              <div class="dispatch-row dispatch-row-recent">
                <div>
                  <span class="cell-label">Order</span>
                  <span class="order-id-badge">#<%= order.id %></span>
                  <div class="cell-value muted" style="margin-top:0.3rem;font-size:0.78rem;">
                    <%= new Date(order.updated_at || order.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) %>
                  </div>
                </div>
                <div>
                  <span class="cell-label">Driver</span>
                  <div class="cell-value"><%= order.driver_name || '—' %></div>
                </div>
                <div>
                  <span class="cell-label">Route</span>
                  <div class="cell-value" style="font-size:0.82rem;">
                    <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;"><%= order.pickup_address %></div>
                    <div style="color:rgba(255,255,255,.45);margin-top:0.15rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;">→ <%= order.dropoff_address %></div>
                  </div>
                </div>
                <div>
                  <span class="cell-label">Customer</span>
                  <div class="cell-value"><%= order.customer_name || '—' %></div>
                </div>
                <div>
                  <span class="cell-label">Status</span>
                  <% const recentBadge = order.status === 'delivered' ? 'badge-green' : (order.status === 'cancelled' ? 'badge-red' : 'badge-gray'); %>
                  <span class="badge <%= recentBadge %>"><%= order.status.replace('_', ' ') %></span>
                  <div class="cell-value muted" style="font-size:0.78rem;margin-top:0.2rem;">
                    $<%= Number(order.price_total).toFixed(2) %>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</body>
</html>
