<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dispatch — Admin — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: var(--bg); }

    .dash-page {
      max-width: 960px;
      margin: 0 auto;
      padding: 80px 1.5rem 4rem;
    }

    /* ── Header ── */
    .dash-header { margin-bottom: 2rem; }
    .dash-header .page-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }
    .dash-header .page-sub {
      color: var(--gray-mid);
      font-size: 0.95rem;
    }

    /* ── Alerts ── */
    .alert {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      margin-bottom: 1.5rem;
      font-weight: 500;
    }
    .alert-success { background: #F0FAF5; color: #166534; border: 1px solid #86C9A0; }
    .alert-error   { background: #FFF7ED; color: #92400E; border: 1px solid #F5C77E; }

    /* ── Back link ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gray-mid);
      text-decoration: none;
      margin-bottom: 1.5rem;
    }
    .back-link:hover { color: var(--orange); }

    /* ── Admin sidebar nav ── */
    .admin-nav {
      display: flex;
      gap: 0.25rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    .admin-nav-link {
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-size: 0.82rem;
      font-weight: 600;
      text-decoration: none;
      border: 1.5px solid transparent;
      transition: all 0.15s;
      color: var(--gray-mid);
      background: var(--white);
    }
    .admin-nav-link:hover {
      border-color: var(--orange);
      color: var(--orange);
    }
    .admin-nav-link.active {
      background: var(--charcoal);
      color: var(--white);
      border-color: var(--charcoal);
    }

    /* ── Section ── */
    .section {
      margin-bottom: 2.5rem;
    }
    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .section-count {
      background: var(--orange);
      color: var(--white);
      border-radius: 99px;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.1rem 0.6rem;
      font-family: 'DM Sans', sans-serif;
    }

    /* ── Table ── */
    .dispatch-table {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 12px;
      overflow: hidden;
    }

    .dispatch-row {
      display: grid;
      padding: 1rem 1.25rem;
      align-items: start;
      gap: 1rem;
      border-bottom: 1px solid var(--gray-light);
    }
    .dispatch-row:last-child { border-bottom: none; }
    .dispatch-row-header {
      background: var(--off-white);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray-mid);
    }

    /* Pending: 6 cols */
    .dispatch-row-pending {
      grid-template-columns: 80px 1fr 1fr 1fr 80px auto;
    }

    /* Active: 6 cols */
    .dispatch-row-active {
      grid-template-columns: 80px 1fr 1fr 1fr 80px auto;
    }

    /* Recent: 5 cols */
    .dispatch-row-recent {
      grid-template-columns: 80px 1fr 1fr 1fr 80px;
    }

    .cell-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gray-mid);
      margin-bottom: 0.3rem;
      display: block;
    }
    .cell-value {
      font-size: 0.88rem;
      color: var(--charcoal);
      font-weight: 500;
      line-height: 1.4;
    }
    .cell-value.muted { color: var(--gray-mid); font-weight: 400; }

    .order-id-badge {
      background: var(--off-white);
      border: 1px solid var(--gray-light);
      border-radius: 4px;
      padding: 0.25rem 0.5rem;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--charcoal);
      font-family: monospace;
    }

    /* Price */
    .price {
      font-weight: 700;
      color: var(--charcoal);
      font-size: 1rem;
    }

    /* Status badge */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.75rem;
      border-radius: 99px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .status-badge.pending     { background: #FFF7ED; color: #92400E; border: 1px solid #F5C77E; }
    .status-badge.assigned     { background: #EFF6FF; color: #1E40AF; border: 1px solid #93C5FD; }
    .status-badge.in_progress  { background: #F0FDF4; color: #166534; border: 1px solid #86C9A0; }
    .status-badge.delivered   { background: #F0FDF4; color: #166534; border: 1px solid #86C9A0; }
    .status-badge.cancelled   { background: #FFF7ED; color: #92400E; border: 1px solid #F5C77E; }

    /* Action buttons */
    .action-form { display: flex; align-items: center; gap: 0.5rem; }
    .action-form select {
      padding: 0.35rem 0.6rem;
      border: 1.5px solid var(--gray-light);
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      color: var(--charcoal);
      background: var(--white);
      cursor: pointer;
    }
    .action-form select:focus { outline: none; border-color: var(--orange); }

    .btn {
      padding: 0.4rem 0.85rem;
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
    }
    .btn:hover { opacity: 0.85; }
    .btn-orange { background: var(--orange); color: var(--white); }
    .btn-green  { background: #16A34A; color: var(--white); }
    .btn-red    { background: #DC2626; color: var(--white); }
    .btn-gray   { background: var(--gray-light); color: var(--gray-mid); cursor: default; }

    /* Driver availability chips */
    .driver-avail-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .driver-chip {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 8px;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      min-width: 200px;
    }
    .driver-chip-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--orange);
      color: var(--white);
      font-weight: 700;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .driver-chip-info .chip-name {
      font-weight: 600;
      font-size: 0.88rem;
      color: var(--charcoal);
      margin-bottom: 0.1rem;
    }
    .driver-chip-info .chip-meta {
      font-size: 0.78rem;
      color: var(--gray-mid);
    }
    .driver-chip-badge {
      margin-left: auto;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.2rem 0.6rem;
      border-radius: 99px;
    }
    .driver-chip-badge.idle    { background: #F0FDF4; color: #166534; border: 1px solid #86C9A0; }
    .driver-chip-badge.busy    { background: #FFF7ED; color: #92400E; border: 1px solid #F5C77E; }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--gray-mid);
    }
    .empty-state-icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.5rem;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
    }
    .empty-state p { font-size: 0.9rem; }

    /* ── Nav ── */
    .dash-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(26,26,26,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.12em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-btn {
      padding: 0.45rem 1rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      border: none;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .nav-btn-primary { background: var(--orange); color: var(--white); }
    .nav-btn-primary:hover { background: var(--orange-light); }
    .nav-btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .nav-btn-secondary:hover { background: rgba(255,255,255,0.18); }

    /* Helper label */
    .helper-tag {
      display: inline-block;
      background: #FFF7ED;
      color: #92400E;
      border: 1px solid #F5C77E;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.1rem 0.4rem;
      margin-left: 0.3rem;
    }

    @media (max-width: 768px) {
      .dispatch-row-pending,
      .dispatch-row-active,
      .dispatch-row-recent {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</head>
<body>
  <nav class="dash-nav">
    <a href="/" class="nav-logo">HAULR</a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-btn nav-btn-secondary">Dashboard</a>
      <a href="/book" class="nav-btn nav-btn-primary">New Booking</a>
      <a href="/admin/logout" class="nav-btn nav-btn-secondary">Logout</a>
    </div>
  </nav>

  <div class="dash-page">
    <div class="dash-header">
      <h1 class="page-title">Dispatch</h1>
      <p class="page-sub">Manage driver assignments, active deliveries, and completed orders.</p>
    </div>

    <a class="back-link" href="/admin">← Back to Admin</a>

    <!-- Flash alerts -->
    <% if (typeof assigned !== 'undefined' && assigned) { %>
      <div class="alert alert-success">Driver assigned successfully.</div>
    <% } %>
    <% if (typeof delivered !== 'undefined' && delivered) { %>
      <div class="alert alert-success">Order marked as delivered.</div>
    <% } %>
    <% if (typeof cancelled !== 'undefined' && cancelled) { %>
      <div class="alert alert-error">Order has been cancelled.</div>
    <% } %>
    <% if (typeof error !== 'undefined' && error === 'missing') { %>
      <div class="alert alert-error">Please select a driver before assigning.</div>
    <% } %>

    <!-- Admin sidebar nav -->
    <div class="admin-nav">
      <a class="admin-nav-link" href="/admin">Overview</a>
      <a class="admin-nav-link" href="/admin/bookings">Bookings</a>
      <a class="admin-nav-link active" href="/admin/dispatch">Dispatch</a>
      <a class="admin-nav-link" href="/admin/drivers">Drivers</a>
      <a class="admin-nav-link" href="/admin/metrics">Metrics</a>
      <a class="admin-nav-link" href="/admin/ratings">Ratings</a>
    </div>

    <!-- ── Driver Availability ── -->
    <div class="section">
      <div class="section-title">
        <span>🚚</span> Driver Availability
        <% if (drivers.length > 0) { %>
          <span class="section-count"><%= drivers.length %></span>
        <% } %>
      </div>
      <% if (drivers.length === 0) { %>
        <div class="dispatch-table">
          <div class="empty-state">
            <div class="empty-state-icon">🚚</div>
            <h2>No active drivers</h2>
            <p>Approve driver applications in the Drivers tab to see them here.</p>
          </div>
        </div>
      <% } else { %>
        <div class="driver-avail-grid">
          <% for (const driver of drivers) { %>
            <% const isBusy = active.some(a => a.driver_id === driver.id); %>
            <div class="driver-chip">
              <div class="driver-chip-avatar"><%= driver.name.charAt(0).toUpperCase() %></div>
              <div class="driver-chip-info">
                <div class="chip-name"><%= driver.name %></div>
                <div class="chip-meta"><%= driver.vehicle_type %> · 📍 <%= driver.city %></div>
              </div>
              <span class="driver-chip-badge <%= isBusy ? 'busy' : 'idle' %>">
                <%= isBusy ? 'On Job' : 'Idle' %>
              </span>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- ── Pending Dispatches ── -->
    <div class="section">
      <div class="section-title">
        <span>⏳</span> Pending Dispatches
        <% if (pending.length > 0) { %>
          <span class="section-count"><%= pending.length %></span>
        <% } %>
      </div>
      <% if (pending.length === 0) { %>
        <div class="dispatch-table">
          <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h2>All clear</h2>
            <p>No orders waiting for a driver.</p>
          </div>
        </div>
      <% } else { %>
        <div class="dispatch-table">
          <div class="dispatch-row dispatch-row-pending dispatch-row-header">
            <div>Order</div>
            <div>Pickup</div>
            <div>Dropoff</div>
            <div>Customer</div>
            <div>Price</div>
            <div>Action</div>
          </div>
          <% for (const order of pending) { %>
            <div class="dispatch-row dispatch-row-pending">
              <div>
                <span class="cell-label">Order</span>
                <span class="order-id-badge">#<%= order.id %></span>
                <div class="cell-value muted" style="margin-top:0.3rem; font-size:0.78rem;">
                  <%= new Date(order.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) %>
                </div>
              </div>
              <div>
                <span class="cell-label">Pickup</span>
                <div class="cell-value"><%= order.pickup_address %></div>
              </div>
              <div>
                <span class="cell-label">Dropoff</span>
                <div class="cell-value"><%= order.dropoff_address %></div>
              </div>
              <div>
                <span class="cell-label">Customer</span>
                <div class="cell-value"><%= order.customer_name || '—' %></div>
                <% if (order.customer_phone) { %>
                  <div class="cell-value muted" style="font-size:0.78rem;"><%= order.customer_phone %></div>
                <% } %>
              </div>
              <div>
                <span class="cell-label">Price</span>
                <span class="price">$<%= Number(order.price_total).toFixed(2) %></span>
              </div>
              <div>
                <% if (drivers.length > 0) { %>
                  <form class="action-form" method="post" action="/admin/dispatch/<%= order.id %>/assign">
                    <select name="driverId" required>
                      <option value="">Select driver…</option>
                      <% for (const driver of drivers) { %>
                        <option value="<%= driver.id %>"><%= driver.name %> · <%= driver.city %></option>
                      <% } %>
                    </select>
                    <input type="hidden" name="driverName" value="">
                    <button type="submit" class="btn btn-orange">Assign</button>
                  </form>
                <% } else { %>
                  <span class="cell-value muted">No drivers</span>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- ── Active Dispatches ── -->
    <div class="section">
      <div class="section-title">
        <span>🚛</span> Active Dispatches
        <% if (active.length > 0) { %>
          <span class="section-count"><%= active.length %></span>
        <% } %>
      </div>
      <% if (active.length === 0) { %>
        <div class="dispatch-table">
          <div class="empty-state">
            <div class="empty-state-icon">🚛</div>
            <h2>No active deliveries</h2>
            <p>Assigned orders will appear here.</p>
          </div>
        </div>
      <% } else { %>
        <div class="dispatch-table">
          <div class="dispatch-row dispatch-row-active dispatch-row-header">
            <div>Order</div>
            <div>Driver</div>
            <div>Pickup → Dropoff</div>
            <div>Customer</div>
            <div>Status</div>
            <div>Actions</div>
          </div>
          <% for (const order of active) { %>
            <div class="dispatch-row dispatch-row-active">
              <div>
                <span class="cell-label">Order</span>
                <span class="order-id-badge">#<%= order.id %></span>
              </div>
              <div>
                <span class="cell-label">Driver</span>
                <div class="cell-value"><%= order.driver_name || '—' %></div>
                <% if (order.driver_phone) { %>
                  <div class="cell-value muted" style="font-size:0.78rem;"><a href="tel:<%= order.driver_phone %>"><%= order.driver_phone %></a></div>
                <% } %>
              </div>
              <div>
                <span class="cell-label">Route</span>
                <div class="cell-value" style="font-size:0.82rem;">
                  <div><%= order.pickup_address %></div>
                  <div style="color:var(--gray-mid);margin-top:0.15rem;">→ <%= order.dropoff_address %></div>
                </div>
              </div>
              <div>
                <span class="cell-label">Customer</span>
                <div class="cell-value"><%= order.customer_name || '—' %></div>
              </div>
              <div>
                <span class="cell-label">Status</span>
                <span class="status-badge <%= order.status %>"><%= order.status.replace('_', ' ') %></span>
                <% if (order.eta_minutes) { %>
                  <div class="cell-value muted" style="font-size:0.78rem;margin-top:0.2rem;">
                    ETA: <%= order.eta_minutes %> min
                  </div>
                <% } %>
              </div>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">
                <form method="post" action="/admin/dispatch/<%= order.id %>/deliver">
                  <button type="submit" class="btn btn-green">Delivered</button>
                </form>
                <form method="post" action="/admin/dispatch/<%= order.id %>/cancel" onsubmit="return confirm('Cancel order #<%= order.id %>?');">
                  <button type="submit" class="btn btn-red">Cancel</button>
                </form>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- ── Recent Completed ── -->
    <div class="section">
      <div class="section-title">
        <span>📋</span> Recent Completed
      </div>
      <% if (recent.length === 0) { %>
        <div class="dispatch-table">
          <div class="empty-state">
            <div class="empty-state-icon">📋</div>
            <h2>No completed orders yet</h2>
          </div>
        </div>
      <% } else { %>
        <div class="dispatch-table">
          <div class="dispatch-row dispatch-row-recent dispatch-row-header">
            <div>Order</div>
            <div>Driver</div>
            <div>Pickup → Dropoff</div>
            <div>Customer</div>
            <div>Final Status</div>
          </div>
          <% for (const order of recent) { %>
            <div class="dispatch-row dispatch-row-recent">
              <div>
                <span class="cell-label">Order</span>
                <span class="order-id-badge">#<%= order.id %></span>
                <div class="cell-value muted" style="margin-top:0.3rem;font-size:0.78rem;">
                  <%= new Date(order.updated_at || order.created_at).toLocaleDateString('en-US', {month:'short',day:'numeric',hour:'numeric',minute:'2-digit'}) %>
                </div>
              </div>
              <div>
                <span class="cell-label">Driver</span>
                <div class="cell-value"><%= order.driver_name || '—' %></div>
              </div>
              <div>
                <span class="cell-label">Route</span>
                <div class="cell-value" style="font-size:0.82rem;">
                  <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;"><%= order.pickup_address %></div>
                  <div style="color:var(--gray-mid);margin-top:0.15rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:220px;">→ <%= order.dropoff_address %></div>
                </div>
              </div>
              <div>
                <span class="cell-label">Customer</span>
                <div class="cell-value"><%= order.customer_name || '—' %></div>
              </div>
              <div>
                <span class="cell-label">Status</span>
                <span class="status-badge <%= order.status %>"><%= order.status.replace('_', ' ') %></span>
                <div class="cell-value muted" style="font-size:0.78rem;margin-top:0.2rem;">
                  $<%= Number(order.price_total).toFixed(2) %>
                </div>
              </div>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>