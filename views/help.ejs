<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Help Center — Shurget</title>
  <meta name="description" content="Shurget Help Center: answers to common questions about booking, pricing, tracking, and driver payouts.">
  <link rel="canonical" href="https://shurget.com/help" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Shurget" />
  <meta property="og:url" content="https://shurget.com/help" />
  <meta property="og:title" content="Help Center — Shurget" />
  <meta property="og:description" content="Answers to common questions about booking, pricing, tracking, and driver payouts." />
  <meta property="og:image" content="https://shurget.com/images/shurget-og.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <%- include('partials/ga4') %>

  <!-- FAQPage JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How does Shurget pricing work?", "acceptedAnswer": { "@type": "Answer", "text": "Shurget charges a base rate by load size: Small $59+, Medium $89+, Large $129+. Add-ons include helpers at $20/hour per helper and rush pickup. A 15% platform fee is added at checkout, and the final price is shown before you confirm." } },
      { "@type": "Question", "name": "What can I haul?", "acceptedAnswer": { "@type": "Answer", "text": "Shurget handles 28+ item types across 6 categories: Furniture (couches, beds, dressers, tables, chairs), Appliances (washers, dryers, fridges, ovens), Electronics (TVs, computers, servers), Construction (lumber, drywall, tile, debris bags), Vehicles (motorcycles, ATVs, lawn equipment), Miscellaneous (hot tubs, pianos, exercise equipment, trampolines). We cannot move hazardous materials, fuel, pressurized containers, or illegal items." } },
      { "@type": "Question", "name": "How fast can I get a pickup?", "acceptedAnswer": { "@type": "Answer", "text": "In Austin, TX, most orders are matched with a driver within 1–2 hours of booking. Timing depends on time of day, load size, and weather. You'll see real-time driver ETA once matched." } },
      { "@type": "Question", "name": "What if no driver accepts my order?", "acceptedAnswer": { "@type": "Answer", "text": "If no driver accepts within a reasonable window, you're placed on a priority waitlist and notified as soon as one picks it up. If we can't match within the expected window, a full refund is issued immediately. You're not charged until a driver is confirmed." } },
      { "@type": "Question", "name": "How do I track my order?", "acceptedAnswer": { "@type": "Answer", "text": "Use your order ID at /track/[your-order-id]. The tracker shows four stages: Pending (finding a driver), Matched (driver assigned, en route to pickup), In Transit (your items are on the move), and Delivered (job complete). You'll also receive SMS/email updates at each stage." } },
      { "@type": "Question", "name": "Can I cancel or reschedule?", "acceptedAnswer": { "@type": "Answer", "text": "Cancellation: Before driver is matched = full refund, no questions asked. After matched = 50% cancellation fee. After pickup starts = no refund. Rescheduling: Contact us before pickup and we can push the window in most cases with no fee. All changes via /contact — mention your order ID." } },
      { "@type": "Question", "name": "What if my item is damaged?", "acceptedAnswer": { "@type": "Answer", "text": "Step 1 — Rate your driver after delivery and flag any issue there. Step 2 — Ratings of 2 or below automatically alert our support team, reviewed within 24 hours. Step 3 — If damage is driver-caused and documented, we'll work toward a resolution including potential compensation. Shurget's Protection policy covers verified driver-caused damage; intentional damage or improper packing is not covered." } },
      { "@type": "Question", "name": "Do you accept tips?", "acceptedAnswer": { "@type": "Answer", "text": "Not currently — tipping is not built into the checkout flow yet. It's on our roadmap. Drivers are paid a fair base rate plus distance and assistance time through Shurget's earnings model. You don't need to tip to ensure a good driver experience." } },
      { "@type": "Question", "name": "Do you serve cities outside Austin?", "acceptedAnswer": { "@type": "Answer", "text": "Austin, TX only — for now. We're building out coverage. Enter your city and email at the bottom of any page to join the waitlist for your area." } },
      { "@type": "Question", "name": "How do I become a Shurget driver?", "acceptedAnswer": { "@type": "Answer", "text": "Requirements: 18+, valid driver's license, own vehicle (cargo van, pickup truck, or larger), pass background check. Steps: 1) Apply at /drive, 2) Complete 4-step onboarding (license, vehicle photos, background check, Stripe Connect payout setup), 3) Start accepting jobs via /driver/jobs. Get paid within 24h of each delivery via Stripe Connect." } },
      { "@type": "Question", "name": "When do drivers get paid?", "acceptedAnswer": { "@type": "Answer", "text": "Within 24 hours of delivery. Shurget uses Stripe Connect for driver payouts. After delivery is marked complete, Shurget releases the payment (minus platform fee) and Stripe processes the transfer to your connected bank account. Funds arrive in 1–2 business days. Minimum payout: $20. No waiting for monthly cycles." } },
      { "@type": "Question", "name": "How do I use a referral code?", "acceptedAnswer": { "@type": "Answer", "text": "$20 off your first order. 1) Get a referral code from a friend. 2) Go to /book. 3) At checkout, find the 'Referral code' field and enter it — the discount applies automatically. One use per account. Codes can't be stacked." } }
    ]
  }
  </script>

  <style>
  /* ══════════════════════════════════════════════════════════════
     HELP CENTER — Shurget Brand System
     Colors: #0a0a0a dark / #111 charcoal / #b84000 btn /
             #ea580c accent / #f8f7f5 off-white / #fff white
     Fonts:  Bebas Neue (headings) · DM Sans (body)
     ══════════════════════════════════════════════════════════════ */

  /* ── Hero ───────────────────────────────────────────────────── */
  .help-hero {
    background: #0a0a0a;
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 8vw, 6rem) clamp(1.5rem, 6vw, 5rem);
    text-align: center;
  }
  .help-hero::before {
    content: '';
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 450px;
    background: radial-gradient(ellipse, rgba(234,88,12,.15) 0%, transparent 65%);
    pointer-events: none;
  }
  .help-hero-inner {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .help-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: 'Bebas Neue', sans-serif;
    font-size: .9rem;
    letter-spacing: .18em;
    color: #ea580c;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .help-hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.0;
    letter-spacing: .04em;
    color: #fff;
    margin-bottom: .75rem;
  }
  .help-hero h1 em { color: #ea580c; font-style: normal; }
  .help-hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(.95rem, 2vw, 1.05rem);
    color: rgba(255,255,255,.6);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  /* ── Search ─────────────────────────────────────────────────── */
  .search-wrap {
    position: relative;
    max-width: 540px;
    margin: 0 auto;
  }
  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: rgba(255,255,255,.35);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: .9rem 3rem .9rem 3rem;
    background: rgba(255,255,255,.06);
    border: 1.5px solid rgba(255,255,255,.12);
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: #fff;
    outline: none;
    transition: border-color .2s, background .2s;
  }
  .search-input::placeholder { color: rgba(255,255,255,.3); }
  .search-input:focus { border-color: #ea580c; background: rgba(255,255,255,.08); }
  .search-clear {
    position: absolute;
    right: .85rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: rgba(255,255,255,.35);
    display: none;
    line-height: 1;
    padding: .25rem;
  }
  .search-clear.visible { display: block; }
  .search-clear:hover { color: #ea580c; }

  /* ── Main content ─────────────────────────────────────────── */
  .help-body {
    background: #f8f7f5;
    padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 6vw, 5rem);
  }
  .help-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Category tiles ─────────────────────────────────────────── */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .85rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 520px) { .category-grid { grid-template-columns: 1fr; } }

  .cat-tile {
    background: #fff;
    border: 1px solid #e8e6e3;
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color .15s, transform .15s, box-shadow .15s;
    text-decoration: none;
  }
  .cat-tile:hover {
    border-color: #ea580c;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
  }
  .cat-icon-box {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: rgba(234,88,12,.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
  }
  .cat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: .9rem;
    font-weight: 600;
    color: #111;
  }
  .cat-count {
    font-family: 'DM Sans', sans-serif;
    font-size: .75rem;
    color: #888;
    margin-top: .1rem;
  }

  /* ── No-results ─────────────────────────────────────────────── */
  .no-results {
    text-align: center;
    padding: 2.5rem 1rem;
    display: none;
  }
  .no-results.visible { display: block; }
  .no-results p {
    font-family: 'DM Sans', sans-serif;
    color: #888;
    font-size: .95rem;
    margin-bottom: .75rem;
  }
  .no-results a {
    display: inline-block;
    padding: .65rem 1.4rem;
    background: #b84000;
    color: #fff;
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background .15s;
  }
  .no-results a:hover { background: #9e3800; }

  /* ── FAQ group labels ──────────────────────────────────────── */
  .faq-list { display: block; }
  .faq-list.hidden { display: none; }

  .faq-group-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.35rem;
    letter-spacing: .08em;
    color: #0a0a0a;
    border-left: 4px solid #ea580c;
    padding-left: .75rem;
    margin: 2.5rem 0 1rem;
  }
  .faq-group-label:first-child { margin-top: 0; }

  /* ── FAQ accordion ─────────────────────────────────────────── */
  .faq-item {
    background: #fff;
    border: 1px solid #e8e6e3;
    border-radius: 10px;
    margin-bottom: .65rem;
    overflow: hidden;
    transition: border-color .15s, box-shadow .15s;
  }
  .faq-item:hover { border-color: #d4d0cb; }
  .faq-item.open { border-color: #ea580c; box-shadow: 0 4px 16px rgba(0,0,0,.07); }

  .faq-q {
    padding: 1rem 1.25rem;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: .93rem;
    color: #111;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    user-select: none;
    line-height: 1.4;
    transition: background .12s;
  }
  .faq-q:hover { background: #fafaf8; }
  .faq-chevron {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(234,88,12,.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .25s, background .15s;
  }
  .faq-chevron svg { width: 10px; height: 10px; stroke: #ea580c; }
  .faq-item.open .faq-chevron { transform: rotate(180deg); background: #ea580c; }
  .faq-item.open .faq-chevron svg { stroke: #fff; }

  .faq-a {
    display: none;
    padding: 0 1.25rem 1.1rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    color: #555;
    line-height: 1.7;
  }
  .faq-item.open .faq-a { display: block; }
  .faq-a p { margin-bottom: .75rem; }
  .faq-a p:last-child { margin-bottom: 0; }
  .faq-a table { width: 100%; border-collapse: collapse; margin: .75rem 0; font-size: .85rem; }
  .faq-a th, .faq-a td { padding: .45rem .75rem; text-align: left; border: 1px solid #e8e6e3; }
  .faq-a th { background: #f8f7f5; font-weight: 600; color: #111; }
  .faq-a strong { color: #111; }
  .faq-a a { color: #b84000; font-weight: 600; text-decoration: none; }
  .faq-a a:hover { text-decoration: underline; }
  .faq-a ul, .faq-a ol { padding-left: 1.25rem; margin: .5rem 0; }
  .faq-a li { margin-bottom: .3rem; }

  /* ── Footer CTA ─────────────────────────────────────────────── */
  .help-cta {
    background: #0a0a0a;
    border-radius: 14px;
    padding: 2.5rem 2rem;
    text-align: center;
    margin-top: 3rem;
    position: relative;
    overflow: hidden;
  }
  .help-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center bottom, rgba(234,88,12,.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .help-cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: .06em;
    color: #fff;
    margin-bottom: .5rem;
    position: relative;
  }
  .help-cta p {
    font-family: 'DM Sans', sans-serif;
    color: rgba(255,255,255,.5);
    font-size: .9rem;
    margin-bottom: 1.25rem;
    position: relative;
  }
  .help-cta a {
    display: inline-block;
    padding: .75rem 1.75rem;
    background: #b84000;
    color: #fff;
    border-radius: 8px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    letter-spacing: .08em;
    text-decoration: none;
    transition: background .15s, transform .15s;
    position: relative;
  }
  .help-cta a:hover { background: #9e3800; transform: translateY(-1px); }
  </style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<%- include('partials/nav') %>

<main id="main-content">

  <!-- ── Hero + Search ── -->
  <section class="help-hero">
    <div class="help-hero-inner">
      <div class="help-eyebrow">Support &middot; FAQs &middot; Guides</div>
      <h1>Help <em>Center</em></h1>
      <p class="help-hero-sub">Find answers fast — search below or browse by topic.</p>

      <div class="search-wrap" role="search">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="search"
          id="faq-search"
          class="search-input"
          placeholder="Search help articles…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search help articles"
        >
        <button class="search-clear" id="search-clear" aria-label="Clear search">✕</button>
      </div>
    </div>
  </section>

  <!-- ── Body ── -->
  <section class="help-body">
    <div class="help-inner">

      <!-- Category tiles -->
      <div class="category-grid" id="category-grid">
        <div class="cat-tile" data-cat="booking" tabindex="0" role="button" aria-label="Browse Booking articles">
          <div class="cat-icon-box" aria-hidden="true">📦</div>
          <div>
            <div class="cat-label">Booking</div>
            <div class="cat-count">3 articles</div>
          </div>
        </div>
        <div class="cat-tile" data-cat="pricing" tabindex="0" role="button" aria-label="Browse Pricing and Payment articles">
          <div class="cat-icon-box" aria-hidden="true">💳</div>
          <div>
            <div class="cat-label">Pricing &amp; Payment</div>
            <div class="cat-count">3 articles</div>
          </div>
        </div>
        <div class="cat-tile" data-cat="tracking" tabindex="0" role="button" aria-label="Browse Tracking and Delivery articles">
          <div class="cat-icon-box" aria-hidden="true">📍</div>
          <div>
            <div class="cat-label">Tracking &amp; Delivery</div>
            <div class="cat-count">3 articles</div>
          </div>
        </div>
        <div class="cat-tile" data-cat="drivers" tabindex="0" role="button" aria-label="Browse Driver articles">
          <div class="cat-icon-box" aria-hidden="true">🚚</div>
          <div>
            <div class="cat-label">Drivers</div>
            <div class="cat-count">3 articles</div>
          </div>
        </div>
      </div>

      <!-- No-results state -->
      <div class="no-results" id="no-results" role="status">
        <p>No results for "<strong id="search-query-display"></strong>"</p>
        <a href="/contact">Contact us →</a>
      </div>

      <!-- FAQ Accordion -->
      <div class="faq-list" id="faq-list">

        <!-- BOOKING -->
        <div class="faq-group-label" data-group="booking">Booking</div>

        <div class="faq-item" id="what-can-i-haul" data-group="booking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            What can I haul?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p>Shurget handles 28+ item types across 6 categories:</p>
            <table>
              <thead><tr><th>Category</th><th>Examples</th></tr></thead>
              <tbody>
                <tr><td>Furniture</td><td>Couches, beds, dressers, tables, chairs</td></tr>
                <tr><td>Appliances</td><td>Washers, dryers, fridges, ovens</td></tr>
                <tr><td>Electronics</td><td>TVs, computers, servers</td></tr>
                <tr><td>Construction</td><td>Lumber, drywall, tile, bags of debris</td></tr>
                <tr><td>Vehicles</td><td>Motorcycles, ATVs, lawn equipment</td></tr>
                <tr><td>Miscellaneous</td><td>Hot tubs, pianos, exercise equipment, trampolines</td></tr>
              </tbody>
            </table>
            <p><strong>What we can't move:</strong> Hazardous materials, fuel, pressurized containers, illegal items.</p>
            <p><a href="/book">Start a booking →</a></p>
          </div>
        </div>

        <div class="faq-item" id="pickup-speed" data-group="booking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            How fast can I get a pickup?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Austin, TX — same-day available.</strong> Most orders are matched with a driver within 1–2 hours of booking.</p>
            <p>Factors that affect timing:</p>
            <ul>
              <li>Time of day (peak hours = longer wait)</li>
              <li>Load size (large loads may take longer to match)</li>
              <li>Weather and traffic</li>
            </ul>
            <p>You'll see real-time driver ETA once matched. No guesswork.</p>
          </div>
        </div>

        <div class="faq-item" id="no-driver-available" data-group="booking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            What if no driver accepts my order?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p>If no driver accepts within a reasonable window:</p>
            <ol>
              <li>You're automatically placed on a <strong>priority waitlist</strong></li>
              <li>We notify you as soon as a driver picks it up</li>
              <li><strong>Full refund</strong> issued immediately if we can't match within the expected window</li>
            </ol>
            <p>No charge until a driver is confirmed.</p>
          </div>
        </div>

        <!-- PRICING & PAYMENT -->
        <div class="faq-group-label" data-group="pricing">Pricing &amp; Payment</div>

        <div class="faq-item" id="how-pricing-works" data-group="pricing">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            How does Shurget pricing work?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p>Shurget charges a base rate by load size:</p>
            <ul>
              <li><strong>Small</strong> — $59+ (e.g., small couch, boxes, 1-person load)</li>
              <li><strong>Medium</strong> — $89+ (e.g., full bedroom set, mid-size furniture)</li>
              <li><strong>Large</strong> — $129+ (e.g., multi-room move, appliances, construction debris)</li>
            </ul>
            <p><strong>Add-ons:</strong></p>
            <ul>
              <li>Helper at pickup/delivery: +$20/hour per helper (select at checkout)</li>
              <li>Rush pickup: varies by availability</li>
            </ul>
            <p><strong>Platform fee:</strong> 15% added at checkout. Final price shown before you confirm.</p>
            <p><a href="/pricing">See full pricing →</a></p>
          </div>
        </div>

        <div class="faq-item" id="cancel-reschedule" data-group="pricing">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            Can I cancel or reschedule?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Cancellation:</strong></p>
            <ul>
              <li><strong>Before driver is matched:</strong> Full refund, no questions asked</li>
              <li><strong>After matched:</strong> 50% cancellation fee (driver is already on the way)</li>
              <li><strong>After pickup starts:</strong> No refund</li>
            </ul>
            <p><strong>Rescheduling:</strong></p>
            <ul>
              <li>Contact us before pickup — we can push the window in most cases</li>
              <li>No fee to reschedule, just confirm driver availability</li>
            </ul>
            <p>All changes via <a href="/contact">/contact</a> — mention your order ID.</p>
          </div>
        </div>

        <div class="faq-item" id="referral-code" data-group="pricing">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            How do I use a referral code?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>$20 off your first order.</strong></p>
            <ol>
              <li>Get a referral code from a friend</li>
              <li>Go to <a href="/book">/book</a></li>
              <li>At checkout, find the <strong>"Referral code" field</strong></li>
              <li>Enter the code — the discount applies automatically</li>
            </ol>
            <p>One use per account. Codes can't be stacked.</p>
          </div>
        </div>

        <!-- TRACKING & DELIVERY -->
        <div class="faq-group-label" data-group="tracking">Tracking &amp; Delivery</div>

        <div class="faq-item" id="track-order" data-group="tracking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            How do I track my order?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p>Use your order ID at <a href="/track">/track</a> — enter your order number and see live status.</p>
            <p>The tracker shows 4 stages:</p>
            <ol>
              <li><strong>Pending</strong> — Order received, finding a driver</li>
              <li><strong>Matched</strong> — Driver assigned, en route to pickup</li>
              <li><strong>In Transit</strong> — Your items are on the move</li>
              <li><strong>Delivered</strong> — Job complete</li>
            </ol>
            <p>You'll also get SMS/email updates at each stage.</p>
            <p><a href="/track">Track your order →</a></p>
          </div>
        </div>

        <div class="faq-item" id="damage-claims" data-group="tracking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            What if my item is damaged?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Step 1 — Rate your driver:</strong> After delivery, you'll be prompted to rate 1–5 stars. Flagging an issue here starts the review process.</p>
            <p><strong>Step 2 — Admin review:</strong> Ratings of 2 or below automatically alert our support team. We review within 24 hours.</p>
            <p><strong>Step 3 — Claims process:</strong> If the damage is driver-caused and documented, we'll work toward a resolution including potential compensation. Have photos ready.</p>
            <p><strong>Note:</strong> Shurget's Protection policy covers verified driver-caused damage. Intentional damage or improper packing is not covered.</p>
          </div>
        </div>

        <div class="faq-item" id="service-areas" data-group="tracking">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            Do you serve cities outside Austin?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Austin, TX only — for now.</strong></p>
            <p>We're building out coverage. Enter your city and email at the bottom of any page to join the waitlist for your area.</p>
            <p>We'd rather do Austin right than spread thin. Expansion is coming.</p>
          </div>
        </div>

        <!-- DRIVERS -->
        <div class="faq-group-label" data-group="drivers">Drivers</div>

        <div class="faq-item" id="become-driver" data-group="drivers">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            How do I become a Shurget driver?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Requirements:</strong></p>
            <ul>
              <li>18+, valid driver's license</li>
              <li>Own vehicle (cargo van, pickup truck, or larger)</li>
              <li>Pass background check</li>
            </ul>
            <p><strong>Steps:</strong></p>
            <ol>
              <li>Apply at <a href="/drive">/drive</a></li>
              <li>Complete the 4-step onboarding wizard (license, vehicle photos, background check, Stripe Connect payout setup)</li>
              <li>Start accepting jobs via <a href="/driver/jobs">/driver/jobs</a></li>
            </ol>
            <p><strong>Earnings:</strong> Set your own schedule. Get paid within 24h of each delivery via Stripe Connect.</p>
            <p><a href="/drive">Apply to drive →</a> &nbsp;·&nbsp; <a href="/drive/earn">See earnings math →</a></p>
          </div>
        </div>

        <div class="faq-item" id="driver-payout" data-group="drivers">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            When do drivers get paid?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Within 24 hours of delivery.</strong></p>
            <p>Shurget uses Stripe Connect for driver payouts. After you complete a delivery and the customer confirms:</p>
            <ol>
              <li>Shurget releases the payment (minus platform fee)</li>
              <li>Stripe processes the transfer to your connected bank account</li>
              <li>Funds arrive in 1–2 business days depending on your bank</li>
            </ol>
            <p><strong>Minimum payout:</strong> $20. No waiting for monthly cycles.</p>
            <p><a href="/driver/payouts">Set up Stripe Connect →</a></p>
          </div>
        </div>

        <div class="faq-item" id="tips" data-group="drivers">
          <div class="faq-q" onclick="toggleFaq(this)" role="button" aria-expanded="false">
            Do you accept tips?
            <span class="faq-chevron" aria-hidden="true">
              <svg viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="faq-a">
            <p><strong>Not currently.</strong> Tipping is not built into the checkout flow yet.</p>
            <p>We know this is a common expectation — it's on our roadmap. For now, drivers are paid a fair base rate + distance + assistance time through Shurget's earnings model. You don't need to tip to ensure a good driver experience.</p>
          </div>
        </div>

      </div><!-- /faq-list -->

      <!-- Footer CTA -->
      <div class="help-cta">
        <div class="help-cta-title">Still Need Help?</div>
        <p>Our team typically responds within a few hours.</p>
        <a href="/contact">Contact Us →</a>
      </div>

    </div><!-- /help-inner -->
  </section>

</main>

<%- include('partials/footer') %>

<script>
  // ── Accordion
  function toggleFaq(el) {
    const item = el.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    item.classList.toggle('open');
    el.setAttribute('aria-expanded', !isOpen);
  }

  // ── Deep-link: open the matching FAQ item if URL has an anchor hash
  (function () {
    var hash = window.location.hash;
    if (hash) {
      var target = document.querySelector(hash);
      if (target && target.classList.contains('faq-item')) {
        target.classList.add('open');
        target.querySelector('.faq-q').setAttribute('aria-expanded', 'true');
        setTimeout(function () { target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 100);
      }
    }
  })();

  // ── Category tile click — scroll to group
  document.querySelectorAll('.cat-tile').forEach(function(tile) {
    function activate() {
      var cat = tile.getAttribute('data-cat');
      var group = document.querySelector('.faq-group-label[data-group="' + cat + '"]');
      if (group) {
        group.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    tile.addEventListener('click', activate);
    tile.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') activate(); });
  });

  // ── Client-side search
  var searchInput  = document.getElementById('faq-search');
  var clearBtn     = document.getElementById('search-clear');
  var faqList      = document.getElementById('faq-list');
  var noResults    = document.getElementById('no-results');
  var queryDisplay = document.getElementById('search-query-display');
  var groupLabels  = faqList.querySelectorAll('.faq-group-label');
  var catGrid      = document.getElementById('category-grid');

  function doSearch(term) {
    term = term.trim().toLowerCase();
    clearBtn.classList.toggle('visible', term.length > 0);

    if (!term) {
      faqList.classList.remove('hidden');
      noResults.classList.remove('visible');
      catGrid.style.display = '';
      faqList.querySelectorAll('.faq-item').forEach(function (item) { item.style.display = ''; });
      groupLabels.forEach(function (lbl) { lbl.style.display = ''; });
      return;
    }

    catGrid.style.display = 'none';
    faqList.classList.remove('hidden');
    var allItems = faqList.querySelectorAll('.faq-item');
    var visibleCount = 0;

    allItems.forEach(function (item) {
      var qText   = item.querySelector('.faq-q').textContent.toLowerCase();
      var aText   = item.querySelector('.faq-a').textContent.toLowerCase();
      var matches = qText.includes(term) || aText.includes(term);
      item.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });

    groupLabels.forEach(function (lbl) {
      var next = lbl.nextElementSibling;
      var hasVisible = false;
      while (next && !next.classList.contains('faq-group-label')) {
        if (next.classList.contains('faq-item') && next.style.display !== 'none') hasVisible = true;
        next = next.nextElementSibling;
      }
      lbl.style.display = hasVisible ? '' : 'none';
    });

    noResults.classList.toggle('visible', visibleCount === 0);
    queryDisplay.textContent = term;
  }

  searchInput.addEventListener('input', function () { doSearch(this.value); });
  clearBtn.addEventListener('click', function () {
    searchInput.value = '';
    searchInput.focus();
    doSearch('');
  });
</script>
</body>
</html>
