<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Drivers — Admin — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: var(--bg); }

    .dash-page {
      max-width: 800px;
      margin: 0 auto;
      padding: 80px 1.5rem 4rem;
    }

    /* ── Header ── */
    .dash-header { margin-bottom: 2rem; }
    .dash-header .page-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }
    .dash-header .page-sub {
      color: var(--gray-mid);
      font-size: 0.95rem;
    }

    /* ── Back link ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gray-mid);
      text-decoration: none;
      margin-bottom: 1.5rem;
    }
    .back-link:hover { color: var(--orange); }

    /* ── Driver table ── */
    .drivers-table {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 12px;
      overflow: hidden;
    }

    .driver-row {
      display: grid;
      grid-template-columns: 1.2fr 1fr 0.8fr auto auto auto;
      gap: 1rem;
      padding: 1rem 1.5rem;
      align-items: start;
      border-bottom: 1px solid var(--gray-light);
    }
    .referral-source { font-size: 0.8rem; color: var(--gray-mid); }
    .referral-source .ref-name { color: var(--charcoal); font-weight: 600; }
    .bounty-paid { color: #166534; font-size: 0.75rem; font-weight: 600; }
    .bounty-pending { color: #92400E; font-size: 0.75rem; }
    .driver-row:last-child { border-bottom: none; }
    .driver-row-header {
      background: var(--off-white);
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gray-mid);
    }

    .driver-info .driver-name {
      font-weight: 600;
      color: var(--charcoal);
      margin-bottom: 0.15rem;
    }
    .driver-info .driver-email {
      font-size: 0.82rem;
      color: var(--gray-mid);
    }
    .driver-info .driver-phone {
      font-size: 0.82rem;
      color: var(--gray-mid);
    }

    .driver-meta .driver-city {
      font-size: 0.85rem;
      color: var(--gray-mid);
    }
    .driver-meta .driver-vehicle {
      font-size: 0.82rem;
      color: var(--gray-mid);
    }

    /* Status badge */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.3rem 0.75rem;
      border-radius: 99px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .status-badge.active   { background: #F0FAF5; color: #166534; border: 1px solid #86C9A0; }
    .status-badge.pending  { background: #FFF7ED; color: #92400E; border: 1px solid #F5C77E; }

    /* Background check badge */
    .bg-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.2rem 0.6rem;
      border-radius: 99px;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-top: 0.3rem;
    }
    .bg-badge.cleared  { background: #F0FAF5; color: #166534; border: 1px solid #86C9A0; }
    .bg-badge.pending { background: #EFF6FF; color: #1D4ED8; border: 1px solid #93C5FD; }
    .bg-badge.failed  { background: #FEF2F2; color: #991B1B; border: 1px solid #FCA5A5; }
    .bg-select { font-size: 0.75rem; padding: 0.2rem 0.5rem; background: var(--white); border: 1.5px solid var(--gray-light); border-radius: 6px; font-family: 'DM Sans', sans-serif; color: var(--charcoal); cursor: pointer; margin-top: 0.25rem; }
    .bg-form { display: flex; flex-direction: column; gap: 0.25rem; }

    /* Activate button */
    .btn-activate {
      padding: 0.45rem 0.9rem;
      background: var(--orange);
      color: var(--white);
      border: none;
      border-radius: 6px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.2s;
      text-decoration: none;
    }
    .btn-activate:hover { background: var(--orange-light); }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--gray-mid);
    }
    .empty-state-icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
    }
    .empty-state p { font-size: 0.9rem; color: var(--gray-mid); }

    /* ── Nav ── */
    .dash-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(26,26,26,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.12em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-btn {
      padding: 0.45rem 1rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .nav-btn-primary { background: var(--orange); color: var(--white); }
    .nav-btn-primary:hover { background: var(--orange-light); }
    .nav-btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .nav-btn-secondary:hover { background: rgba(255,255,255,0.18); }

    /* Admin sidebar nav */
    .admin-nav { display: flex; gap: 0.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .admin-nav-link { padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; transition: all 0.15s; color: var(--gray-mid); background: var(--white); }
    .admin-nav-link:hover { border-color: var(--orange); color: var(--orange); }
    .admin-nav-link.active { background: var(--charcoal); color: var(--white); border-color: var(--charcoal); }
  </style>
</head>
<body>
  <nav class="dash-nav">
    <a href="/" class="nav-logo">HAULR</a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-btn nav-btn-secondary">Dashboard</a>
      <a href="/book" class="nav-btn nav-btn-primary">New Booking</a>
      <a href="/admin/logout" class="nav-btn nav-btn-secondary">Logout</a>
    </div>
  </nav>

  <div class="dash-page">
    <div class="dash-header">
      <h1 class="page-title">Drivers</h1>
      <p class="page-sub">Review and manage driver applications.</p>
    </div>

    <div class="admin-nav">
      <a class="admin-nav-link" href="/admin">Overview</a>
      <a class="admin-nav-link" href="/admin/bookings">Bookings</a>
      <a class="admin-nav-link" href="/admin/dispatch">Dispatch</a>
      <a class="admin-nav-link active" href="/admin/drivers">Drivers</a>
      <a class="admin-nav-link" href="/admin/metrics">Metrics</a>
      <a class="admin-nav-link" href="/admin/ratings">Ratings</a>
      <a class="admin-nav-link" href="/admin/disputes">Disputes</a>
    </div>

    <a class="back-link" href="/admin">← Back to Admin</a>

    <% if (drivers.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🚚</div>
        <h2>No applications yet</h2>
        <p>Driver applications will appear here once they submit the signup form.</p>
      </div>
    <% } else { %>
      <div class="drivers-table">
        <div class="driver-row driver-row-header">
          <div>Driver</div>
          <div>Location & Vehicle</div>
          <div>Referral Source</div>
          <div>BG Check</div>
          <div>Status</div>
          <div>Action</div>
        </div>
        <% for (const driver of drivers) { %>
          <div class="driver-row">
            <div class="driver-info">
              <div class="driver-name"><%= driver.name %></div>
              <div class="driver-email"><%= driver.email %></div>
              <div class="driver-phone"><%= driver.phone %></div>
            </div>
            <div class="driver-meta">
              <div class="driver-city">📍 <%= driver.city %></div>
              <div class="driver-vehicle">🚛 <%= driver.vehicle_type %></div>
            </div>
            <div class="referral-source">
              <% if (driver.referred_by_driver_name) { %>
                <div>Referred by <span class="ref-name"><%= driver.referred_by_driver_name %></span></div>
                <% if (driver.referral_bounty_paid_at) { %>
                  <div class="bounty-paid">✓ $50 bounty paid</div>
                <% } else { %>
                  <div class="bounty-pending">Bounty pending (3 hauls)</div>
                <% } %>
              <% } else { %>
                <span style="color:var(--gray-mid)">—</span>
              <% } %>
            </div>
            <div>
              <span class="bg-badge <%= driver.background_check_status || 'pending' %>">
                <% if ((driver.background_check_status || 'pending') === 'cleared') { %>✓<% } %>
                BG: <%= driver.background_check_status || 'pending' %>
              </span>
              <% if (driver.status === 'active') { %>
              <form method="post" action="/admin/drivers/<%= driver.id %>/background-check" class="bg-form">
                <select name="status" class="bg-select" onchange="this.form.submit()">
                  <option value="pending" <%= (driver.background_check_status || '') === 'pending' ? 'selected' : '' %>>pending</option>
                  <option value="cleared"  <%= driver.background_check_status === 'cleared' ? 'selected' : '' %>>cleared</option>
                  <option value="failed"   <%= driver.background_check_status === 'failed' ? 'selected' : '' %>>failed</option>
                </select>
              </form>
              <% } %>
            </div>
            <div>
              <span class="status-badge <%= driver.status %>"><%= driver.status %></span>
            </div>
            <div>
              <% if (driver.status === 'pending') { %>
                <form method="post" action="/admin/drivers/<%= driver.id %>/activate">
                  <button type="submit" class="btn-activate">Activate</button>
                </form>
              <% } else { %>
                <span style="font-size:0.8rem;color:var(--gray-mid);">—</span>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</body>
</html>