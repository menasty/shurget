<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Metrics — Shurget Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #0a0a0a; color: #f8f7f5; font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    .admin-topnav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,.92); backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,.07);
      height: 58px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 clamp(1.25rem,4vw,2.5rem);
    }
    .admin-topnav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .12em; color: #fff; text-decoration: none; display: flex; align-items: center; gap: .5rem; }
    .admin-topnav-logo span { color: #ea580c; }
    .admin-topnav-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(234,88,12,.15); color: #ea580c; border: 1px solid rgba(234,88,12,.3); border-radius: 4px; padding: .15rem .5rem; }
    .tn-btn { font-size: .78rem; font-weight: 600; text-decoration: none; padding: .4rem .9rem; border-radius: 6px; border: none; cursor: pointer; transition: background .2s; font-family: 'DM Sans', sans-serif; }
    .tn-btn-ghost { background: rgba(255,255,255,.07); color: rgba(255,255,255,.65); }
    .tn-btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; }
    .tn-btn-primary { background: #b84000; color: #fff; }
    .tn-btn-primary:hover { background: #9e3800; }

    .admin-layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 58px); }
    @media (max-width: 768px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { display: flex; overflow-x: auto; padding: .75rem; gap: .4rem; border-right: none; border-bottom: 1px solid rgba(255,255,255,.07); } .sidebar-section-label { display: none; } }
    .admin-sidebar { background: #111; border-right: 1px solid rgba(255,255,255,.07); padding: 1.25rem .75rem; display: flex; flex-direction: column; gap: .15rem; }
    .sidebar-section-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.3); padding: .9rem .6rem .35rem; }
    .sidebar-link { display: flex; align-items: center; gap: .6rem; padding: .52rem .7rem; border-radius: 7px; text-decoration: none; color: rgba(255,255,255,.55); font-size: .82rem; font-weight: 500; transition: all .18s; white-space: nowrap; }
    .sidebar-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
    .sidebar-link.active { background: rgba(184,64,0,.18); color: #ea580c; font-weight: 600; }
    .sidebar-icon { font-size: 1rem; flex-shrink: 0; }
    .admin-main { padding: clamp(1.5rem,4vw,2.5rem); overflow-x: hidden; }

    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: .06em; color: #fff; margin: 0 0 .25rem; }
    .page-subtitle { font-size: .88rem; color: rgba(255,255,255,.45); margin: 0 0 1.75rem; }

    .card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.5rem; }
    .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; }

    .data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .data-table th { background: #111; color: rgba(255,255,255,.45); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; padding: .65rem 1rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,.07); }
    .data-table td { padding: .75rem 1rem; border-bottom: 1px solid rgba(255,255,255,.04); color: #f8f7f5; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: rgba(255,255,255,.03); }
    .table-wrap { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; overflow: hidden; }

    .badge { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: .25rem .6rem; border-radius: 5px; }
    .badge-green  { background: rgba(22,163,74,.15);  color: #4ade80; border: 1px solid rgba(22,163,74,.25); }
    .badge-orange { background: rgba(234,88,12,.15);  color: #ea580c; border: 1px solid rgba(234,88,12,.25); }
    .badge-red    { background: rgba(239,68,68,.15);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .badge-gray   { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.1); }
    .badge-blue   { background: rgba(59,130,246,.15); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }

    .btn { display: inline-flex; align-items: center; gap: .4rem; font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600; padding: .5rem 1rem; border-radius: 7px; border: none; cursor: pointer; text-decoration: none; transition: all .2s; }
    .btn-primary { background: #b84000; color: #fff; }
    .btn-primary:hover { background: #9e3800; }
    .btn-ghost { background: rgba(255,255,255,.06); color: rgba(255,255,255,.65); border: 1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { background: rgba(255,255,255,.1); color: #fff; }
    .btn-danger { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .btn-danger:hover { background: rgba(239,68,68,.25); }

    .form-input { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; transition: border-color .2s; }
    .form-input:focus { border-color: #b84000; }
    .form-select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; }

    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.75rem; }
    .metric-card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.25rem 1.5rem; }
    .metric-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin: 0 0 .4rem; }
    .metric-value { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: .04em; color: #fff; line-height: 1; margin: 0; }
    .metric-sub { font-size: .75rem; color: rgba(255,255,255,.35); margin: .3rem 0 0; }
    .metric-value.orange { color: #ea580c; }
    .metric-value.green { color: #4ade80; }
    .metric-card.revenue { border-color: rgba(234,88,12,.3); }

    .alert { border-radius: 9px; padding: .75rem 1.1rem; font-size: .88rem; margin-bottom: 1.25rem; }
    .alert-success { background: rgba(22,163,74,.12); border: 1px solid rgba(22,163,74,.25); color: #4ade80; }
    .alert-error { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25); color: #f87171; }

    /* Section */
    .section { margin-bottom: 2.25rem; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.35rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; display: flex; align-items: center; gap: .55rem; }

    /* Bar chart for status / tier */
    .bar-chart { display: flex; flex-direction: column; gap: .75rem; }
    .bar-row { display: grid; grid-template-columns: 150px 1fr 60px; align-items: center; gap: 1rem; }
    .bar-label { font-size: .82rem; font-weight: 500; color: #f8f7f5; text-transform: capitalize; }
    .bar-track { background: rgba(255,255,255,.05); border-radius: 4px; height: 28px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 4px; background: #ea580c; transition: width .4s ease; }
    .bar-fill.green { background: #4ade80; }
    .bar-fill.blue  { background: #60a5fa; }
    .bar-fill.amber { background: #ea580c; }
    .bar-fill.gray  { background: rgba(255,255,255,.35); }
    .bar-count { font-size: .82rem; font-weight: 600; color: #f8f7f5; text-align: right; }

    /* Daily volume chart */
    .daily-chart-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.5rem; }
    .daily-chart-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .05em; color: #fff; }
    .daily-chart-sub { font-size: .8rem; color: rgba(255,255,255,.45); }
    .chart-area { display: flex; align-items: flex-end; gap: 3px; height: 160px; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,.07); }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; height: 100%; gap: 0; }
    .chart-bar { width: 100%; max-width: 20px; background: #ea580c; border-radius: 3px 3px 0 0; min-height: 2px; transition: background .2s; cursor: default; position: relative; }
    .chart-bar:hover { background: #b84000; }
    .chart-bar:hover::after { content: attr(data-count) ' order(s)'; position: absolute; bottom: calc(100% + 4px); left: 50%; transform: translateX(-50%); background: #0a0a0a; border: 1px solid rgba(255,255,255,.1); color: #f8f7f5; font-size: .68rem; white-space: nowrap; padding: .25rem .4rem; border-radius: 4px; z-index: 10; }
    .chart-label { font-size: .6rem; color: rgba(255,255,255,.35); margin-top: .35rem; }
    .chart-empty { flex: 1; display: flex; align-items: center; justify-content: center; height: 160px; color: rgba(255,255,255,.45); font-size: .85rem; }

    /* Top routes */
    .routes-list { display: flex; flex-direction: column; gap: .75rem; }
    .route-row { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 8px; padding: .85rem 1.1rem; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: .75rem; }
    .route-rank { width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.1); font-size: .75rem; font-weight: 700; color: #f8f7f5; display: flex; align-items: center; justify-content: center; }
    .route-names { font-size: .88rem; color: #f8f7f5; font-weight: 500; }
    .route-names span { color: rgba(255,255,255,.45); font-weight: 400; }
    .route-meta { text-align: right; }
    .route-count { font-size: .85rem; font-weight: 700; color: #f8f7f5; }
    .route-revenue { font-size: .75rem; color: #4ade80; font-weight: 600; }

    @media (max-width: 600px) {
      .bar-row { grid-template-columns: 90px 1fr 48px; }
    }
  </style>
</head>
<body>

  <!-- Top Nav -->
  <header class="admin-topnav">
    <a href="/admin" class="admin-topnav-logo">SHUR<span>GET</span> <span class="admin-topnav-badge">Admin</span></a>
    <div style="display:flex;align-items:center;gap:.65rem;">
      <a href="/admin" class="tn-btn tn-btn-ghost">← Dashboard</a>
      <a href="/admin/logout" class="tn-btn tn-btn-primary">Logout</a>
    </div>
  </header>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-section-label">Operations</div>
      <a href="/admin/dispatch" class="sidebar-link"><span class="sidebar-icon">🚛</span> Dispatch</a>
      <a href="/admin/bookings" class="sidebar-link"><span class="sidebar-icon">📋</span> Bookings</a>
      <a href="/admin/drivers" class="sidebar-link"><span class="sidebar-icon">🧑‍✈️</span> Drivers</a>
      <div class="sidebar-section-label">Analytics</div>
      <a href="/admin/metrics" class="sidebar-link active"><span class="sidebar-icon">📊</span> Metrics</a>
      <a href="/admin/ratings" class="sidebar-link"><span class="sidebar-icon">⭐</span> Ratings</a>
      <a href="/admin/attribution" class="sidebar-link"><span class="sidebar-icon">🔗</span> Attribution</a>
      <div class="sidebar-section-label">Platform</div>
      <a href="/admin/partners" class="sidebar-link"><span class="sidebar-icon">🤝</span> Partners</a>
      <a href="/admin/disputes" class="sidebar-link"><span class="sidebar-icon">⚖️</span> Disputes</a>
      <a href="/admin/surge" class="sidebar-link"><span class="sidebar-icon">⚡</span> Surge</a>
    </aside>

    <main class="admin-main">
      <h1 class="page-title">Order Metrics</h1>
      <p class="page-subtitle">Platform performance at a glance — all data from the orders table.</p>

      <% const t = metrics.totals; %>
      <% const totalOrders = parseInt(t.total_orders) || 0; %>
      <% const completed = parseInt(t.completed) || 0; %>
      <% const cancelled = parseInt(t.cancelled) || 0; %>
      <% const completionRate = totalOrders > 0 ? ((completed / totalOrders) * 100).toFixed(1) : '0.0'; %>
      <% const cancelRate = totalOrders > 0 ? ((cancelled / totalOrders) * 100).toFixed(1) : '0.0'; %>
      <% const avgOrderValue = parseFloat(t.avg_order_value) || 0; %>

      <% const weekOrders = parseInt(metrics.week.cnt) || 0; %>
      <% const monthOrders = parseInt(metrics.month.cnt) || 0; %>
      <% const weekRevenue = parseFloat(metrics.week.revenue) || 0; %>
      <% const monthRevenue = parseFloat(metrics.month.revenue) || 0; %>
      <% const totalRevenue = parseFloat(t.total_revenue) || 0; %>

      <!-- KPI Cards -->
      <div class="section">
        <div class="section-title"><span>📊</span> Key Performance Indicators</div>
        <div class="metric-grid">
          <div class="metric-card">
            <div class="metric-label">Total Orders (All-Time)</div>
            <div class="metric-value"><%= totalOrders.toLocaleString() %></div>
            <div class="metric-sub"><%= monthOrders %> this month · <%= weekOrders %> this week</div>
          </div>
          <div class="metric-card revenue">
            <div class="metric-label">Platform Take (Revenue)</div>
            <div class="metric-value green">$<%= totalRevenue.toFixed(2) %></div>
            <div class="metric-sub">$<%= monthRevenue.toFixed(2) %> this month · $<%= weekRevenue.toFixed(2) %> this week</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Avg Order Value</div>
            <div class="metric-value">$<%= avgOrderValue.toFixed(2) %></div>
            <div class="metric-sub">across all <%= totalOrders %> orders</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Completion Rate</div>
            <div class="metric-value green"><%= completionRate %>%</div>
            <div class="metric-sub"><%= completed %> completed · <%= cancelRate %>% cancelled</div>
          </div>
        </div>
      </div>

      <!-- Review Email Metrics -->
      <div class="section">
        <div class="section-title"><span>⭐</span> Review Email Performance</div>
        <div class="metric-grid">
          <div class="metric-card">
            <div class="metric-label">Review Emails Sent</div>
            <div class="metric-value orange"><%= parseInt(reviewEmailStats && reviewEmailStats.cnt) || 0 %></div>
            <div class="metric-sub">Delivered 2hr post-delivery (idempotent)</div>
          </div>
          <div class="metric-card">
            <div class="metric-label">Ratings from Email</div>
            <% const emailRatingsCount = parseInt(ratingStats && ratingStats.cnt) || 0; %>
            <% const emailsSent = parseInt(reviewEmailStats && reviewEmailStats.cnt) || 0; %>
            <% const convRate = emailsSent > 0 ? ((emailRatingsCount / emailsSent) * 100).toFixed(1) : '0.0'; %>
            <% const avgRating = parseFloat(ratingStats && ratingStats.avg_rating) || 0; %>
            <div class="metric-value"><%= emailRatingsCount %></div>
            <div class="metric-sub"><%= convRate %>% of emails converted · avg <%= avgRating > 0 ? avgRating.toFixed(1) + '★' : 'N/A' %></div>
          </div>
        </div>
      </div>

      <!-- Orders by Status -->
      <div class="section">
        <div class="section-title"><span>📋</span> Orders by Status</div>
        <div class="card">
          <div class="bar-chart">
            <% const statusMap = { delivered: { label: 'Delivered', fill: 'green' }, assigned: { label: 'Assigned', fill: 'blue' }, in_progress: { label: 'In Progress', fill: 'blue' }, paid: { label: 'Paid (Unassigned)', fill: 'amber' }, pending: { label: 'Pending', fill: 'amber' }, pending_payment: { label: 'Pending Payment', fill: 'amber' }, cancelled: { label: 'Cancelled', fill: 'gray' } }; %>
            <% const statusCounts = {}; byStatus.forEach(r => { statusCounts[r.status] = parseInt(r.cnt); }); %>
            <% const maxStatus = Math.max(...byStatus.map(r => parseInt(r.cnt)), 1); %>
            <% ['delivered', 'assigned', 'in_progress', 'paid', 'pending', 'pending_payment', 'cancelled'].forEach(status => { %>
              <% const cnt = statusCounts[status] || 0; %>
              <% if (cnt > 0) { %>
                <% const meta = statusMap[status] || { label: status, fill: 'gray' }; %>
                <div class="bar-row">
                  <div class="bar-label"><%= meta.label %></div>
                  <div class="bar-track">
                    <div class="bar-fill <%= meta.fill %>" style="width: <%= (cnt / maxStatus * 100).toFixed(1) %>%;"></div>
                  </div>
                  <div class="bar-count"><%= cnt %></div>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Orders by Size Tier -->
      <div class="section">
        <div class="section-title"><span>📦</span> Orders by Size Tier</div>
        <div class="card">
          <div class="bar-chart">
            <% const tierMap = { small: { label: 'Small (< $50 base)', fill: 'blue' }, medium: { label: 'Medium ($50–$69)', fill: 'amber' }, large: { label: 'Large ($70+)', fill: 'amber' } }; %>
            <% const tierCounts = {}; byTier.forEach(r => { tierCounts[r.tier] = parseInt(r.cnt); }); %>
            <% const maxTier = Math.max(...byTier.map(r => parseInt(r.cnt)), 1); %>
            <% ['small', 'medium', 'large'].forEach(tier => { %>
              <% const cnt = tierCounts[tier] || 0; %>
              <% if (cnt > 0) { %>
                <% const meta = tierMap[tier] || { label: tier, fill: 'gray' }; %>
                <div class="bar-row">
                  <div class="bar-label"><%= meta.label %></div>
                  <div class="bar-track">
                    <div class="bar-fill <%= meta.fill %>" style="width: <%= (cnt / maxTier * 100).toFixed(1) %>%;"></div>
                  </div>
                  <div class="bar-count"><%= cnt %></div>
                </div>
              <% } %>
            <% }); %>
          </div>
        </div>
      </div>

      <!-- Daily Order Volume (30 days) -->
      <div class="section">
        <div class="section-title"><span>📈</span> Daily Order Volume — Last 30 Days</div>
        <div class="card">
          <div class="daily-chart-header">
            <div class="daily-chart-title">Order Volume</div>
            <div class="daily-chart-sub">bar height = relative volume</div>
          </div>
          <% if (daily.length > 0) { %>
            <% const maxDaily = Math.max(...daily.map(d => parseInt(d.orders)), 1); %>
            <div class="chart-area">
              <% daily.forEach(d => { %>
                <div class="chart-bar-wrap" title="<%= new Date(d.date).toLocaleDateString('en-US', {month:'short',day:'numeric'}) %>: <%= d.orders %> order(s)">
                  <div class="chart-bar" style="height: <%= Math.max(4, (parseInt(d.orders) / maxDaily * 100)).toFixed(1) %>%;" data-count="<%= d.orders %>"></div>
                  <div class="chart-label"><%= new Date(d.date).toLocaleDateString('en-US', {month:'numeric',day:'numeric'}) %></div>
                </div>
              <% }); %>
            </div>
          <% } else { %>
            <div class="chart-empty">No order data in the last 30 days.</div>
          <% } %>
        </div>
      </div>

      <!-- Top Routes -->
      <div class="section">
        <div class="section-title"><span>🛣️</span> Top Routes</div>
        <% if (topRoutes.length > 0) { %>
          <div class="routes-list">
            <% topRoutes.forEach((route, i) => { %>
              <div class="route-row">
                <div class="route-rank"><%= i + 1 %></div>
                <div class="route-names">
                  <%= route.pickup_city %><span> → </span><%= route.dropoff_city %>
                </div>
                <div class="route-meta">
                  <div class="route-count"><%= route.cnt %> order<%= route.cnt !== '1' ? 's' : '' %></div>
                  <% if (parseFloat(route.total_revenue) > 0) { %>
                    <div class="route-revenue">$<%= parseFloat(route.total_revenue).toFixed(2) %> total</div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="table-wrap">
            <div style="padding: 2rem; text-align: center; color: rgba(255,255,255,.45); font-size: 0.9rem;">
              No route data yet — orders will populate this once they come in.
            </div>
          </div>
        <% } %>
      </div>
    </main>
  </div>
</body>
</html>
