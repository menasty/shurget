<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ratings — Admin — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: var(--bg); }

    .dash-page {
      max-width: 680px;
      margin: 0 auto;
      padding: 80px 1.5rem 4rem;
    }

    /* ── Header ── */
    .dash-header { margin-bottom: 2rem; }
    .dash-header .page-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }
    .dash-header .page-sub {
      color: var(--gray-mid);
      font-size: 0.95rem;
    }

    /* ── Back link ── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gray-mid);
      text-decoration: none;
      margin-bottom: 1.5rem;
    }
    .back-link:hover { color: var(--orange); }

    /* Empty state */
    .empty-state {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--gray-mid);
    }
    .empty-state-icon { font-size: 3rem; margin-bottom: 1rem; }
    .empty-state h2 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      color: var(--charcoal);
      margin-bottom: 0.5rem;
    }
    .empty-state p { font-size: 0.9rem; color: var(--gray-mid); }

    /* ── Nav ── */
    .dash-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(26,26,26,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.12em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-btn {
      padding: 0.45rem 1rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .nav-btn-primary { background: var(--orange); color: var(--white); }
    .nav-btn-primary:hover { background: var(--orange-light); }
    .nav-btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .nav-btn-secondary:hover { background: rgba(255,255,255,0.18); }

    /* Admin sidebar nav */
    .admin-nav { display: flex; gap: 0.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .admin-nav-link { padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; transition: all 0.15s; color: var(--gray-mid); background: var(--white); }
    .admin-nav-link:hover { border-color: var(--orange); color: var(--orange); }
    .admin-nav-link.active { background: var(--charcoal); color: var(--white); border-color: var(--charcoal); }
  </style>
</head>
<body>
  <nav class="dash-nav">
    <a href="/" class="nav-logo">HAULR</a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-btn nav-btn-secondary">Dashboard</a>
      <a href="/book" class="nav-btn nav-btn-primary">New Booking</a>
      <a href="/admin/logout" class="nav-btn nav-btn-secondary">Logout</a>
    </div>
  </nav>

  <div class="dash-page">
    <div class="dash-header">
      <h1 class="page-title">Ratings</h1>
      <p class="page-sub">Driver performance and customer feedback.</p>
    </div>

    <div class="admin-nav">
      <a class="admin-nav-link" href="/admin">Overview</a>
      <a class="admin-nav-link" href="/admin/bookings">Bookings</a>
      <a class="admin-nav-link" href="/admin/dispatch">Dispatch</a>
      <a class="admin-nav-link" href="/admin/drivers">Drivers</a>
      <a class="admin-nav-link" href="/admin/metrics">Metrics</a>
      <a class="admin-nav-link active" href="/admin/ratings">Ratings</a>
    </div>

    <a class="back-link" href="/admin">← Back to Admin</a>

    <div class="empty-state">
      <div class="empty-state-icon">⭐</div>
      <h2>Coming Soon</h2>
      <p>Driver ratings and customer feedback features are currently under development.</p>
    </div>
  </div>
</body>
</html>