<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    body { background: var(--bg); }

    .dash-page {
      max-width: 680px;
      margin: 0 auto;
      padding: 80px 1.5rem 4rem;
    }

    /* ── Header ── */
    .dash-header { margin-bottom: 2rem; }
    .dash-header .page-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 2.5rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 0.25rem;
    }
    .dash-header .page-sub {
      color: var(--gray-mid);
      font-size: 0.95rem;
    }

    /* ── Admin section cards ── */
    .admin-sections { display: flex; flex-direction: column; gap: 1rem; }

    .admin-card {
      background: var(--white);
      border: 1.5px solid var(--gray-light);
      border-radius: 12px;
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      text-decoration: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .admin-card:hover {
      border-color: var(--orange);
      box-shadow: 0 4px 20px rgba(232,93,4,0.12);
    }
    .admin-card-icon {
      font-size: 2rem;
      flex-shrink: 0;
    }
    .admin-card-text .admin-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 0.05em;
      color: var(--charcoal);
      margin-bottom: 0.2rem;
    }
    .admin-card-text .admin-card-desc {
      font-size: 0.85rem;
      color: var(--gray-mid);
    }
    .admin-card-arrow {
      margin-left: auto;
      font-size: 1.25rem;
      color: var(--orange);
    }

    /* ── Nav ── */
    .dash-nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      background: rgba(26,26,26,0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.75rem;
      letter-spacing: 0.12em;
      color: var(--white);
      text-decoration: none;
    }
    .nav-right { display: flex; align-items: center; gap: 1rem; }
    .nav-btn {
      padding: 0.45rem 1rem;
      border-radius: 4px;
      font-size: 0.8rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.2s;
    }
    .nav-btn-primary { background: var(--orange); color: var(--white); }
    .nav-btn-primary:hover { background: var(--orange-light); }
    .nav-btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.8); }
    .nav-btn-secondary:hover { background: rgba(255,255,255,0.18); }

    /* Admin sidebar nav */
    .admin-nav { display: flex; gap: 0.25rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
    .admin-nav-link { padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.82rem; font-weight: 600; text-decoration: none; border: 1.5px solid transparent; transition: all 0.15s; color: var(--gray-mid); background: var(--white); }
    .admin-nav-link:hover { border-color: var(--orange); color: var(--orange); }
    .admin-nav-link.active { background: var(--charcoal); color: var(--white); border-color: var(--charcoal); }
  </style>
</head>
<body>
  <nav class="dash-nav">
    <a href="/" class="nav-logo">HAULR</a>
    <div class="nav-right">
      <a href="/dashboard" class="nav-btn nav-btn-secondary">Dashboard</a>
      <a href="/book" class="nav-btn nav-btn-primary">New Booking</a>
      <a href="/admin/logout" class="nav-btn nav-btn-secondary">Logout</a>
    </div>
  </nav>

  <div class="dash-page">
    <div class="dash-header">
      <h1 class="page-title">Admin</h1>
      <p class="page-sub">Manage drivers, ratings, and platform settings.</p>
    </div>

    <div class="admin-nav">
      <a class="admin-nav-link active" href="/admin">Overview</a>
      <a class="admin-nav-link" href="/admin/bookings">Bookings</a>
      <a class="admin-nav-link" href="/admin/dispatch">Dispatch</a>
      <a class="admin-nav-link" href="/admin/drivers">Drivers</a>
      <a class="admin-nav-link" href="/admin/metrics">Metrics</a>
      <a class="admin-nav-link" href="/admin/ratings">Ratings</a>
    </div>

    <div class="admin-sections">
      <a class="admin-card" href="/admin/dispatch">
        <div class="admin-card-icon">🚛</div>
        <div class="admin-card-text">
          <div class="admin-card-title">Dispatch</div>
          <div class="admin-card-desc">Assign drivers, track active deliveries, review completed orders</div>
        </div>
        <div class="admin-card-arrow">→</div>
      </a>

      <a class="admin-card" href="/admin/drivers">
        <div class="admin-card-icon">🚚</div>
        <div class="admin-card-text">
          <div class="admin-card-title">Drivers</div>
          <div class="admin-card-desc">Review and activate driver applications</div>
        </div>
        <div class="admin-card-arrow">→</div>
      </a>

      <a class="admin-card" href="/admin/ratings">
        <div class="admin-card-icon">⭐</div>
        <div class="admin-card-text">
          <div class="admin-card-title">Ratings</div>
          <div class="admin-card-desc">View driver performance and customer feedback</div>
        </div>
        <div class="admin-card-arrow">→</div>
      </a>
    </div>
  </div>
</body>
</html>