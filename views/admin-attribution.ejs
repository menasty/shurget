<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Attribution — Shurget Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { background: #0a0a0a; color: #f8f7f5; font-family: 'DM Sans', sans-serif; min-height: 100vh; }

    .admin-topnav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,.92); backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255,255,255,.07);
      height: 58px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 clamp(1.25rem,4vw,2.5rem);
    }
    .admin-topnav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: .12em; color: #fff; text-decoration: none; display: flex; align-items: center; gap: .5rem; }
    .admin-topnav-logo span { color: #ea580c; }
    .admin-topnav-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; background: rgba(234,88,12,.15); color: #ea580c; border: 1px solid rgba(234,88,12,.3); border-radius: 4px; padding: .15rem .5rem; }
    .tn-btn { font-size: .78rem; font-weight: 600; text-decoration: none; padding: .4rem .9rem; border-radius: 6px; border: none; cursor: pointer; transition: background .2s; font-family: 'DM Sans', sans-serif; }
    .tn-btn-ghost { background: rgba(255,255,255,.07); color: rgba(255,255,255,.65); }
    .tn-btn-ghost:hover { background: rgba(255,255,255,.13); color: #fff; }
    .tn-btn-primary { background: #b84000; color: #fff; }
    .tn-btn-primary:hover { background: #9e3800; }

    .admin-layout { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 58px); }
    @media (max-width: 768px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { display: flex; overflow-x: auto; padding: .75rem; gap: .4rem; border-right: none; border-bottom: 1px solid rgba(255,255,255,.07); } .sidebar-section-label { display: none; } }
    .admin-sidebar { background: #111; border-right: 1px solid rgba(255,255,255,.07); padding: 1.25rem .75rem; display: flex; flex-direction: column; gap: .15rem; }
    .sidebar-section-label { font-size: .65rem; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; color: rgba(255,255,255,.3); padding: .9rem .6rem .35rem; }
    .sidebar-link { display: flex; align-items: center; gap: .6rem; padding: .52rem .7rem; border-radius: 7px; text-decoration: none; color: rgba(255,255,255,.55); font-size: .82rem; font-weight: 500; transition: all .18s; white-space: nowrap; }
    .sidebar-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.85); }
    .sidebar-link.active { background: rgba(184,64,0,.18); color: #ea580c; font-weight: 600; }
    .sidebar-icon { font-size: 1rem; flex-shrink: 0; }
    .admin-main { padding: clamp(1.5rem,4vw,2.5rem); overflow-x: hidden; }

    .page-title { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: .06em; color: #fff; margin: 0 0 .25rem; }
    .page-subtitle { font-size: .88rem; color: rgba(255,255,255,.45); margin: 0 0 1.75rem; }

    .card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.5rem; }
    .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 1.2rem; letter-spacing: .05em; color: #fff; margin: 0 0 1rem; }

    .data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .data-table th { background: #111; color: rgba(255,255,255,.45); font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; padding: .65rem 1rem; text-align: left; border-bottom: 1px solid rgba(255,255,255,.07); white-space: nowrap; }
    .data-table td { padding: .75rem 1rem; border-bottom: 1px solid rgba(255,255,255,.04); color: #f8f7f5; vertical-align: middle; }
    .data-table tr:last-child td { border-bottom: none; }
    .data-table tr:hover td { background: rgba(255,255,255,.03); }
    .data-table .num { text-align: right; font-variant-numeric: tabular-nums; }
    .table-wrap { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; overflow: hidden; padding: .5rem 1.25rem; overflow-x: auto; }

    .badge { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; padding: .25rem .6rem; border-radius: 5px; }
    .badge-green  { background: rgba(22,163,74,.15);  color: #4ade80; border: 1px solid rgba(22,163,74,.25); }
    .badge-orange { background: rgba(234,88,12,.15);  color: #ea580c; border: 1px solid rgba(234,88,12,.25); }
    .badge-red    { background: rgba(239,68,68,.15);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .badge-gray   { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); border: 1px solid rgba(255,255,255,.1); }
    .badge-blue   { background: rgba(59,130,246,.15); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }
    .badge-purple { background: rgba(168,85,247,.15); color: #c084fc; border: 1px solid rgba(168,85,247,.25); }

    .btn { display: inline-flex; align-items: center; gap: .4rem; font-family: 'DM Sans', sans-serif; font-size: .82rem; font-weight: 600; padding: .5rem 1rem; border-radius: 7px; border: none; cursor: pointer; text-decoration: none; transition: all .2s; }
    .btn-primary { background: #b84000; color: #fff; }
    .btn-primary:hover { background: #9e3800; }
    .btn-ghost { background: rgba(255,255,255,.06); color: rgba(255,255,255,.65); border: 1px solid rgba(255,255,255,.1); }
    .btn-ghost:hover { background: rgba(255,255,255,.1); color: #fff; }
    .btn-danger { background: rgba(239,68,68,.15); color: #f87171; border: 1px solid rgba(239,68,68,.25); }
    .btn-danger:hover { background: rgba(239,68,68,.25); }

    .form-input { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .9rem; padding: .55rem .85rem; outline: none; transition: border-color .2s; }
    .form-input:focus { border-color: #b84000; }
    .form-select { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #f8f7f5; font-family: 'DM Sans', sans-serif; font-size: .85rem; padding: .4rem .65rem; outline: none; cursor: pointer; }
    .form-select:focus { border-color: #b84000; }

    .metric-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.75rem; }
    .metric-card { background: #111; border: 1px solid rgba(255,255,255,.07); border-radius: 12px; padding: 1.25rem 1.5rem; }
    .metric-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin: 0 0 .4rem; }
    .metric-value { font-family: 'Bebas Neue', sans-serif; font-size: 2.2rem; letter-spacing: .04em; color: #fff; line-height: 1; margin: 0; }
    .metric-sub { font-size: .75rem; color: rgba(255,255,255,.35); margin: .3rem 0 0; }

    .alert { border-radius: 9px; padding: .75rem 1.1rem; font-size: .88rem; margin-bottom: 1.25rem; }
    .alert-success { background: rgba(22,163,74,.12); border: 1px solid rgba(22,163,74,.25); color: #4ade80; }
    .alert-error { background: rgba(239,68,68,.1); border: 1px solid rgba(239,68,68,.25); color: #f87171; }

    /* Attribution-specific extras */
    .filter-row { display: flex; align-items: center; gap: .75rem; margin-bottom: 1.75rem; flex-wrap: wrap; }
    .filter-label { font-size: .8rem; color: rgba(255,255,255,.45); }
    .filter-btn { padding: .4rem .9rem; border-radius: 7px; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.05); font-size: .82rem; font-weight: 600; cursor: pointer; color: rgba(255,255,255,.65); text-decoration: none; transition: all .2s; }
    .filter-btn:hover { background: rgba(255,255,255,.09); color: #fff; }
    .filter-btn.active { background: rgba(184,64,0,.18); border-color: #b84000; color: #ea580c; }
    .export-btn { margin-left: auto; }

    .empty { color: rgba(255,255,255,.35); font-size: .9rem; padding: 1.5rem 0; }

    .source-chip { display: inline-flex; align-items: center; font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: .25rem .6rem; border-radius: 5px; background: rgba(59,130,246,.15); color: #60a5fa; border: 1px solid rgba(59,130,246,.25); }
    .source-chip.referral { background: rgba(234,88,12,.15); color: #ea580c; border-color: rgba(234,88,12,.25); }
    .source-chip.seo { background: rgba(22,163,74,.15); color: #4ade80; border-color: rgba(22,163,74,.25); }
    .source-chip.widget { background: rgba(168,85,247,.15); color: #c084fc; border-color: rgba(168,85,247,.25); }
    .source-chip.drive_earn { background: rgba(239,68,68,.15); color: #f87171; border-color: rgba(239,68,68,.25); }
    .source-chip.twitter { background: rgba(59,130,246,.15); color: #60a5fa; border-color: rgba(59,130,246,.25); }
    .source-chip.direct { background: rgba(255,255,255,.07); color: rgba(255,255,255,.5); border-color: rgba(255,255,255,.1); }

    /* Tabs */
    .tabs { display: flex; gap: 0; border-bottom: 1px solid rgba(255,255,255,.07); margin-bottom: 1.5rem; }
    .tab { padding: .6rem 1.1rem; font-size: .88rem; font-weight: 600; color: rgba(255,255,255,.45); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: color .2s; }
    .tab:hover { color: rgba(255,255,255,.75); }
    .tab.active { color: #ea580c; border-bottom-color: #ea580c; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    .info-card { background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.06); border-radius: 10px; padding: 1.1rem 1.4rem; margin-top: 1.25rem; }
    .info-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.35); margin: 0 0 .5rem; display: flex; align-items: center; gap: .4rem; }
    .info-code { display: block; background: rgba(0,0,0,.4); padding: .65rem .9rem; border-radius: 6px; font-size: .85rem; color: #ea580c; border: 1px solid rgba(255,255,255,.08); font-family: 'DM Sans', monospace; margin: .5rem 0; overflow-x: auto; }
    .info-note { margin: .5rem 0 0; font-size: .82rem; color: rgba(255,255,255,.4); }

    .funnel-card { background: rgba(22,163,74,.06); border: 1px solid rgba(22,163,74,.2); border-radius: 10px; padding: 1.1rem 1.4rem; margin-top: 1.25rem; }
    .funnel-title { font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #4ade80; margin: 0 0 .75rem; }
    .funnel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; }
    .funnel-label { font-size: .7rem; color: rgba(255,255,255,.4); text-transform: uppercase; letter-spacing: .06em; margin-bottom: .3rem; }
    .funnel-value { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: #fff; letter-spacing: .04em; }
  </style>
</head>
<body>

  <!-- Top Nav -->
  <header class="admin-topnav">
    <a href="/admin" class="admin-topnav-logo">SHUR<span>GET</span> <span class="admin-topnav-badge">Admin</span></a>
    <div style="display:flex;align-items:center;gap:.65rem;">
      <a href="/admin" class="tn-btn tn-btn-ghost">← Dashboard</a>
      <a href="/admin/logout" class="tn-btn tn-btn-primary">Logout</a>
    </div>
  </header>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar" role="navigation" aria-label="Admin sections">
      <div class="sidebar-section-label">Operations</div>
      <a href="/admin/dispatch" class="sidebar-link"><span class="sidebar-icon">🚛</span> Dispatch</a>
      <a href="/admin/bookings" class="sidebar-link"><span class="sidebar-icon">📋</span> Bookings</a>
      <a href="/admin/drivers" class="sidebar-link"><span class="sidebar-icon">🧑‍✈️</span> Drivers</a>
      <div class="sidebar-section-label">Analytics</div>
      <a href="/admin/metrics" class="sidebar-link"><span class="sidebar-icon">📊</span> Metrics</a>
      <a href="/admin/ratings" class="sidebar-link"><span class="sidebar-icon">⭐</span> Ratings</a>
      <a href="/admin/attribution" class="sidebar-link active"><span class="sidebar-icon">🔗</span> Attribution</a>
      <div class="sidebar-section-label">Platform</div>
      <a href="/admin/partners" class="sidebar-link"><span class="sidebar-icon">🤝</span> Partners</a>
      <a href="/admin/disputes" class="sidebar-link"><span class="sidebar-icon">⚖️</span> Disputes</a>
      <a href="/admin/surge" class="sidebar-link"><span class="sidebar-icon">⚡</span> Surge</a>
    </aside>

    <main class="admin-main">
      <h1 class="page-title">Attribution Dashboard</h1>
      <p class="page-subtitle">Bookings and driver signups by UTM source. Last-touch for bookings; first-touch for signups.</p>

      <!-- Date range filter -->
      <div class="filter-row">
        <span class="filter-label">Period:</span>
        <% ['7d','30d','all'].forEach(function(r){ %>
          <a href="/admin/attribution?range=<%= r %>"
             class="filter-btn<%= range === r ? ' active' : '' %>">
            <%= r === '7d' ? 'Last 7 days' : r === '30d' ? 'Last 30 days' : 'All time' %>
          </a>
        <% }); %>
      </div>

      <%
        const totalBookings = bookings.reduce((s, r) => s + (r.bookings || 0), 0);
        const totalRevenue  = bookings.reduce((s, r) => s + parseFloat(r.gross_revenue || 0), 0);
        const totalNetFee   = bookings.reduce((s, r) => s + parseFloat(r.net_fee || 0), 0);
        const totalDrivers  = drivers.reduce((s, r) => s + (r.signups || 0), 0);
        const avgOrderValue = totalBookings > 0 ? totalRevenue / totalBookings : 0;
      %>
      <!-- Summary cards -->
      <div class="metric-grid">
        <div class="metric-card">
          <p class="metric-label">Total Bookings</p>
          <p class="metric-value"><%= totalBookings %></p>
          <p class="metric-sub">with UTM or direct</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Gross Revenue</p>
          <p class="metric-value">$<%= totalRevenue.toFixed(0) %></p>
          <p class="metric-sub">all attributed orders</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Service Fee Net</p>
          <p class="metric-value">$<%= totalNetFee.toFixed(0) %></p>
          <p class="metric-sub">15% platform fee</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Avg Order Value</p>
          <p class="metric-value">$<%= avgOrderValue.toFixed(0) %></p>
          <p class="metric-sub">across all sources</p>
        </div>
        <div class="metric-card">
          <p class="metric-label">Driver Signups</p>
          <p class="metric-value"><%= totalDrivers %></p>
          <p class="metric-sub">attributed applications</p>
        </div>
      </div>

      <!-- Tabs -->
      <div class="tabs">
        <div class="tab active" onclick="showTab('bookings')">Bookings by Source</div>
        <div class="tab" onclick="showTab('drivers')">Driver Signups</div>
        <div class="tab" onclick="showTab('referrals')">Referral Funnel</div>
      </div>

      <!-- Bookings tab -->
      <div id="tab-bookings" class="tab-panel active">
        <div style="display:flex;justify-content:flex-end;margin-bottom:.75rem;">
          <a href="/admin/attribution/export.csv?range=<%= range %>&type=bookings" class="btn btn-ghost export-btn">⬇ Export CSV</a>
        </div>
        <div class="table-wrap">
          <% if (bookings.length === 0) { %>
            <p class="empty">No booking attribution data yet. UTM params will be captured on new orders.</p>
          <% } else { %>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Source</th>
                  <th>Medium</th>
                  <th>Campaign</th>
                  <th class="num">Bookings</th>
                  <th class="num">Gross Revenue</th>
                  <th class="num">Net Fee</th>
                  <th class="num">Avg Order Value</th>
                </tr>
              </thead>
              <tbody>
                <% bookings.forEach(function(r){ %>
                  <tr>
                    <td>
                      <span class="source-chip <%= r.source %>"><%= r.source %></span>
                    </td>
                    <td style="color:rgba(255,255,255,.45);"><%= r.medium %></td>
                    <td style="color:rgba(255,255,255,.45);font-size:.82rem;"><%= r.campaign %></td>
                    <td class="num" style="font-weight:600;"><%= r.bookings %></td>
                    <td class="num">$<%= parseFloat(r.gross_revenue || 0).toFixed(2) %></td>
                    <td class="num">$<%= parseFloat(r.net_fee || 0).toFixed(2) %></td>
                    <td class="num">$<%= parseFloat(r.avg_order_value || 0).toFixed(2) %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>

      <!-- Driver Signups tab -->
      <div id="tab-drivers" class="tab-panel">
        <div style="display:flex;justify-content:flex-end;margin-bottom:.75rem;">
          <a href="/admin/attribution/export.csv?range=<%= range %>&type=drivers" class="btn btn-ghost export-btn">⬇ Export CSV</a>
        </div>
        <div class="table-wrap">
          <% if (drivers.length === 0) { %>
            <p class="empty">No driver signup attribution data yet. UTM params will be captured on new applications.</p>
          <% } else { %>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Source</th>
                  <th>Medium</th>
                  <th>Campaign</th>
                  <th class="num">Signups</th>
                </tr>
              </thead>
              <tbody>
                <% drivers.forEach(function(r){ %>
                  <tr>
                    <td><span class="source-chip <%= r.source %>"><%= r.source %></span></td>
                    <td style="color:rgba(255,255,255,.45);"><%= r.medium %></td>
                    <td style="color:rgba(255,255,255,.45);font-size:.82rem;"><%= r.campaign %></td>
                    <td class="num" style="font-weight:600;"><%= r.signups %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>

        <!-- Twitter UTM convention note -->
        <div class="info-card">
          <div class="info-title">🐦 Twitter Driver Recruitment — UTM Convention</div>
          <p style="margin:0 0 .3rem;font-size:.85rem;color:rgba(255,255,255,.55);">Tag all Twitter/X driver recruitment links with:</p>
          <code class="info-code">utm_source=twitter&amp;utm_medium=social&amp;utm_campaign=driver_recruit_jun</code>
          <p class="info-note">Increment campaign suffix (jun → jul) monthly so you can compare cohorts.</p>
        </div>
      </div>

      <!-- Referral Funnel tab -->
      <div id="tab-referrals" class="tab-panel">
        <div style="display:flex;justify-content:flex-end;margin-bottom:.75rem;">
          <a href="/admin/attribution/export.csv?range=<%= range %>&type=referrals" class="btn btn-ghost export-btn">⬇ Export CSV</a>
        </div>
        <div class="table-wrap">
          <% if (referrals.length === 0) { %>
            <p class="empty">No referral codes issued yet.</p>
          <% } else { %>
            <table class="data-table">
              <thead>
                <tr>
                  <th>Code</th>
                  <th>Owner Email</th>
                  <th class="num">Redemptions</th>
                  <th class="num">Paid Orders</th>
                  <th class="num">Discount Paid</th>
                </tr>
              </thead>
              <tbody>
                <% referrals.forEach(function(r){ %>
                  <tr>
                    <td style="font-family:monospace;font-weight:700;letter-spacing:.1em;color:#ea580c;"><%= r.code %></td>
                    <td style="color:rgba(255,255,255,.45);font-size:.85rem;"><%= r.owner_email %></td>
                    <td class="num"><%= r.redemptions || 0 %></td>
                    <td class="num"><%= r.paid_orders || 0 %></td>
                    <td class="num">$<%= r.discount_paid_cents ? (r.discount_paid_cents / 100).toFixed(2) : '0.00' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
        <%
          const codesIssued = referrals.length;
          const totalRedemptions = referrals.reduce((s, r) => s + parseInt(r.redemptions || 0), 0);
          const totalPaid = referrals.reduce((s, r) => s + parseInt(r.paid_orders || 0), 0);
          const totalDiscount = referrals.reduce((s, r) => s + parseInt(r.discount_paid_cents || 0), 0);
        %>
        <div class="funnel-card">
          <div class="funnel-title">📐 Referral Funnel Summary</div>
          <div class="funnel-grid">
            <div><div class="funnel-label">Codes Issued</div><div class="funnel-value"><%= codesIssued %></div></div>
            <div><div class="funnel-label">Redemptions</div><div class="funnel-value"><%= totalRedemptions %></div></div>
            <div><div class="funnel-label">Paid Orders</div><div class="funnel-value"><%= totalPaid %></div></div>
            <div><div class="funnel-label">$20 Discounts Paid</div><div class="funnel-value">$<%= (totalDiscount / 100).toFixed(0) %></div></div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    function showTab(name) {
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      document.querySelectorAll('.tab')[['bookings','drivers','referrals'].indexOf(name)].classList.add('active');
    }
  </script>
</body>
</html>
