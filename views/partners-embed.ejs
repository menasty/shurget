<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Widget Demo — Shurget Partner Integration</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <%- include('partials/ga4') %>
  <style>
    /* ─── Demo layout ─── */
    .demo-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 5rem clamp(1.5rem, 5vw, 3rem);
    }
    .demo-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .demo-header .section-label { margin-bottom: 0.75rem; display: block; }
    .demo-header h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      color: var(--charcoal);
      margin-bottom: 1rem;
    }
    .demo-header p {
      color: var(--gray-mid);
      font-size: 1.05rem;
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ─── Fake product page ─── */
    .fake-store-bar {
      background: #1a1a1a;
      color: #fff;
      padding: 10px 20px;
      font-size: 0.78rem;
      font-family: 'DM Sans', sans-serif;
      display: flex;
      align-items: center;
      gap: 1rem;
      border-radius: 10px 10px 0 0;
    }
    .fake-store-bar .store-name {
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: -0.01em;
    }
    .fake-store-bar .store-nav {
      display: flex;
      gap: 1.25rem;
      margin-left: auto;
      font-size: 0.82rem;
      opacity: 0.65;
    }
    .fake-store-bar .cart-icon {
      margin-left: 1rem;
      font-size: 1.1rem;
    }
    .fake-store-frame {
      background: #fafafa;
      border: 1.5px solid #e0e0e0;
      border-radius: 0 0 12px 12px;
      padding: clamp(1.5rem, 4vw, 3rem);
    }
    .fake-pdp {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
    @media (max-width: 680px) {
      .fake-pdp { grid-template-columns: 1fr; gap: 2rem; }
    }
    .fake-product-image {
      background: linear-gradient(135deg, #f0ebe4, #e8ddd2);
      border-radius: 10px;
      aspect-ratio: 4/3;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 5rem;
    }
    .fake-product-brand {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #999;
      margin-bottom: 0.4rem;
    }
    .fake-product-name {
      font-size: 1.6rem;
      font-weight: 700;
      color: #1a1a1a;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }
    .fake-product-price {
      font-size: 1.5rem;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 1rem;
    }
    .fake-product-desc {
      font-size: 0.9rem;
      color: #666;
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .fake-add-to-cart {
      background: #1a1a1a;
      color: #fff;
      border: none;
      padding: 13px 24px;
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      cursor: default;
      width: 100%;
      margin-bottom: 2px;
    }
    .delivery-options-label {
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #aaa;
      margin-top: 1.25rem;
      margin-bottom: 0.5rem;
    }
    .widget-container {
      /* The widget.js script renders the button immediately after itself */
    }

    /* ─── Snippet generator ─── */
    .snippet-section {
      background: var(--charcoal);
      border-radius: 14px;
      padding: clamp(2rem, 4vw, 3rem);
      margin-top: 3.5rem;
      color: var(--white);
    }
    .snippet-section h2 {
      font-size: clamp(1.5rem, 3vw, 2.2rem);
      color: var(--white);
      margin-bottom: 0.5rem;
    }
    .snippet-section p {
      color: rgba(255,255,255,0.6);
      font-size: 0.95rem;
      margin-bottom: 2rem;
      max-width: 520px;
      line-height: 1.65;
    }

    .snippet-form {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 680px) { .snippet-form { grid-template-columns: 1fr; } }
    .snippet-field { display: flex; flex-direction: column; gap: 0.35rem; }
    .snippet-field label {
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.5);
    }
    .snippet-field input, .snippet-field select {
      padding: 9px 12px;
      border: 1.5px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      background: rgba(255,255,255,0.07);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.15s;
    }
    .snippet-field input:focus, .snippet-field select:focus {
      border-color: var(--orange-light);
    }
    .snippet-field select option { background: #2a2a2a; color: #fff; }

    .snippet-output {
      background: #0f0f0f;
      border: 1.5px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
      font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace;
      font-size: 0.82rem;
      color: #7dd3a8;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.7;
      position: relative;
    }
    .copy-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      background: var(--orange);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 6px 14px;
      font-size: 0.78rem;
      font-weight: 600;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.15s;
    }
    .copy-btn:hover { background: #c25a00; }
    .copy-btn.copied { background: #15803d; }

    /* ─── Back link ─── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--orange);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      margin-bottom: 2rem;
    }
    .back-link:hover { text-decoration: underline; }

    /* ─── Disclaimer badge ─── */
    .demo-badge {
      display: inline-block;
      background: #fff3e0;
      color: #E86A00;
      border: 1.5px solid #ffd5a3;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 4px 12px;
      border-radius: 99px;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <!-- ─── Page header ─── -->
  <div class="demo-wrap">
    <a href="/partners" class="back-link">← Back to Partners</a>

    <div class="demo-header">
      <span class="section-label">Live Demo</span>
      <h1>The widget, on a real product page.</h1>
      <p>This is exactly what your customers see. One script tag added to your product page — that's the entire integration.</p>
    </div>

    <!-- ─── Fake product page ─── -->
    <div>
      <div class="fake-store-bar">
        <span class="store-name">Couch Potatoes</span>
        <span class="store-nav">
          <span>Living Room</span>
          <span>Bedroom</span>
          <span>Appliances</span>
          <span>Outdoor</span>
        </span>
        <span class="cart-icon">🛒 1</span>
      </div>
      <div class="fake-store-frame">
        <span class="demo-badge">Demo Product Page</span>
        <div class="fake-pdp">
          <div class="fake-product-image">🛋️</div>
          <div>
            <div class="fake-product-brand">Couch Potatoes</div>
            <div class="fake-product-name">The Bentwood 3-Seat Sectional Sofa</div>
            <div class="fake-product-price">$1,249</div>
            <p class="fake-product-desc">
              Premium mid-century frame with high-resilience foam cushions. 112&quot; wide, available in 8 fabric colors. Ships flat from our Austin warehouse.
            </p>
            <button class="fake-add-to-cart">Add to Cart</button>

            <div class="delivery-options-label">Delivery Options</div>
            <div class="widget-container">
              <!-- ↓ This is the one-line integration. Partners drop this on their PDP. -->
              <script
                src="/widget.js"
                data-item="sofa"
                data-weight="standard"
                data-origin-zip="78704"
                data-partner="couch-potatoes"
                data-label="Shurget it home — instant quote"
              ></script>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ─── Snippet generator ─── -->
    <div class="snippet-section">
      <h2>Generate your snippet</h2>
      <p>Enter your store ZIP and item categories to get the exact script tag to paste on your product pages.</p>

      <div class="snippet-form">
        <div class="snippet-field">
          <label>Your Store ZIP</label>
          <input type="text" id="gen-zip" placeholder="78704" maxlength="5" inputmode="numeric" value="78704">
        </div>
        <div class="snippet-field">
          <label>Item Type</label>
          <select id="gen-item">
            <option value="sofa">Sofa / Couch</option>
            <option value="armchair">Armchair</option>
            <option value="dresser">Dresser</option>
            <option value="mattress">Mattress</option>
            <option value="refrigerator">Refrigerator</option>
            <option value="washer-dryer">Washer / Dryer</option>
            <option value="dishwasher">Dishwasher</option>
            <option value="tv">Large TV</option>
            <option value="exercise-equipment">Exercise Equipment</option>
            <option value="grill">Grill</option>
            <option value="dining-table">Dining Table</option>
            <option value="desk">Desk</option>
            <option value="bed-frame">Bed Frame</option>
            <option value="other">Other Large Item</option>
          </select>
        </div>
        <div class="snippet-field">
          <label>Partner Slug <span style="opacity:0.5;font-size:0.68rem;text-transform:none;">(for attribution)</span></label>
          <input type="text" id="gen-partner" placeholder="your-store-name" value="my-store">
        </div>
      </div>

      <div class="snippet-output" id="snippet-output">
        <button class="copy-btn" id="copy-btn" onclick="copySnippet()">Copy</button>
        <span id="snippet-text">&lt;script
  src="https://shurget.com/widget.js"
  data-item="sofa"
  data-origin-zip="78704"
  data-partner="my-store"
  data-label="Shurget it home — instant quote"
&gt;&lt;/script&gt;</span>
      </div>

      <p style="margin-top:1.5rem;margin-bottom:0;font-size:0.82rem;color:rgba(255,255,255,0.4);">
        That's the entire integration. Drop it next to your "Add to Cart" button. No API keys. No backend changes.
        <a href="/partners#pilot-form" style="color:var(--orange-light);text-decoration:underline;margin-left:4px;">Ready to go live? →</a>
      </p>
    </div>

  </div><!-- /.demo-wrap -->

  <%- include('partials/footer') %>

  <script>
    // Live snippet generation
    var genZip     = document.getElementById('gen-zip');
    var genItem    = document.getElementById('gen-item');
    var genPartner = document.getElementById('gen-partner');
    var snippetEl  = document.getElementById('snippet-text');

    function updateSnippet() {
      var zip     = genZip.value.trim() || '78704';
      var item    = genItem.value || 'sofa';
      var partner = genPartner.value.trim().toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-') || 'my-store';

      snippetEl.textContent =
        '<script\n' +
        '  src="https://shurget.com/widget.js"\n' +
        '  data-item="' + item + '"\n' +
        '  data-origin-zip="' + zip + '"\n' +
        '  data-partner="' + partner + '"\n' +
        '  data-label="Shurget it home \u2014 instant quote"\n' +
        '>\x3c/script>';
    }

    genZip.addEventListener('input', updateSnippet);
    genItem.addEventListener('change', updateSnippet);
    genPartner.addEventListener('input', updateSnippet);

    function copySnippet() {
      var text = snippetEl.textContent;
      navigator.clipboard.writeText(text).then(function () {
        var btn = document.getElementById('copy-btn');
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function () {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      }).catch(function () {
        // Fallback for older browsers
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        var btn = document.getElementById('copy-btn');
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(function () {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      });
    }
  </script>
  <!-- Polsia Analytics --><script>(function(){var slug="shurget-5";if(!slug)return;var vid=localStorage.getItem('polsia_vid');if(!vid){vid='xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g,function(c){var r=Math.random()*16|0;return (c==='x'?r:(r&0x3|0x8)).toString(16);});localStorage.setItem('polsia_vid',vid);}new Image().src='https://polsia.com/api/beacon/pixel?s='+encodeURIComponent(slug)+'&v='+encodeURIComponent(vid);})();</script>
</body>
</html>
